# Database Configuration
# Use a unique, high-entropy password generated for your environment.
DB_PASSWORD=replace_with_a_generated_database_password
DB_PORT=5432

# JWT Configuration (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_with_a_generated_jwt_secret_min_256_bits
JWT_EXPIRATION=86400000

# API Configuration
API_PORT=8080
SPRING_PROFILE=prod
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT=1000
RATE_LIMIT_REFILL=60

# PgAdmin (Optional - only with --profile tools)
# Use a non-default email and a unique password if PgAdmin is enabled.
PGADMIN_EMAIL=replace_with_admin_email@example.com
PGADMIN_PASSWORD=replace_with_a_generated_pgadmin_password
PGADMIN_PORT=5050