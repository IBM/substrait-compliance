# Database Configuration
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# JWT Configuration (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_min_256_bits_required
JWT_EXPIRATION=86400000

# API Configuration
API_PORT=8080
SPRING_PROFILE=prod
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT=1000
RATE_LIMIT_REFILL=60

# PgAdmin (Optional - only with --profile tools)
PGADMIN_EMAIL=admin@substrait.io
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050