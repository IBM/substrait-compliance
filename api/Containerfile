# Multi-stage build for Substrait Compliance API
# Optimized for Podman but compatible with Docker

# Stage 1: Build
FROM gradle:8.5-jdk11 AS builder

WORKDIR /build

# Copy gradle files first for better caching
COPY settings.gradle .
COPY sdk/java/build.gradle sdk/java/
COPY api/build.gradle api/

# Download dependencies (cached layer)
RUN gradle :api:dependencies --no-daemon || true

# Copy source code
COPY sdk/java/src sdk/java/src
COPY api/src api/src

# Build the application
RUN gradle :api:bootJar --no-daemon

# Stage 2: Runtime
FROM eclipse-temurin:11-jre-alpine

# Install curl for healthcheck
RUN apk add --no-cache curl

WORKDIR /app

# Copy the built JAR from builder stage
COPY --from=builder /build/api/build/libs/*.jar app.jar

# Create non-root user for security
RUN addgroup -S spring && adduser -S spring -G spring
RUN chown -R spring:spring /app

# Switch to non-root user
USER spring:spring

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD curl -f http://localhost:8080/actuator/health || exit 1

# JVM options for container environment
ENV JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0"

# Run the application
ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]