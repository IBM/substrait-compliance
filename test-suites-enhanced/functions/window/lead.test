# basic: Basic examples without any special cases
lead(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30), (4, 40)) = (20, 30, 40, Null)::i32
lead(value::i32, 2) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30), (4, 40)) = (30, 40, Null, Null)::i32

# default_value: Examples with default value
lead(value::i32, 1, 0) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (20, 30, 0)::i32
lead(value::i32, 2, -1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (30, -1, -1)::i32

# partition: Examples with partitioning
lead(value::i32, 1) OVER (PARTITION BY category::str ORDER BY id::i32) WITH (('A', 1, 10), ('A', 2, 20), ('B', 3, 30), ('B', 4, 40)) = (20, Null, 40, Null)::i32
lead(salary::i32, 1, 0) OVER (PARTITION BY dept::str ORDER BY id::i32) WITH (('Sales', 1, 5000), ('Sales', 2, 6000), ('IT', 3, 7000)) = (6000, 0, 0)::i32

# offset_zero: Examples with offset 0 (returns same value)
lead(value::i32, 0) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (10, 20, 30)::i32

# null_values: Examples with null values in data
lead(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, Null), (3, 30)) = (Null, 30, Null)::i32
lead(value::i32, 1, 0) OVER (ORDER BY id::i32) WITH ((1, Null), (2, 20), (3, Null)) = (20, Null, 0)::i32

# string_type: Examples with string data type
lead(name::str, 1) OVER (ORDER BY id::i32) WITH ((1, 'Alice'), (2, 'Bob'), (3, 'Charlie')) = ('Bob', 'Charlie', Null)::str
lead(name::str, 1, 'Unknown') OVER (ORDER BY id::i32) WITH ((1, 'Alice'), (2, 'Bob')) = ('Bob', 'Unknown')::str

# floating_point: Examples with floating point values
lead(value::fp64, 1) OVER (ORDER BY id::i32) WITH ((1, 1.5), (2, 2.5), (3, 3.5)) = (2.5, 3.5, Null)::fp64
lead(value::fp64, 1, 0.0) OVER (ORDER BY id::i32) WITH ((1, 1.5), (2, 2.5)) = (2.5, 0.0)::fp64

# large_offset: Examples with large offset
lead(value::i32, 5) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (Null, Null, Null)::i32
lead(value::i32, 10, -1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20)) = (-1, -1)::i32

# comparison_with_lag: Demonstrating lead vs lag behavior
lead(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (20, 30, Null)::i32

