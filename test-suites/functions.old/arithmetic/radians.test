### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic degree to radian conversion
radians(0::fp64) = 0::fp64
radians(90::fp64) = 1.5707963267948966::fp64
radians(180::fp64) = 3.141592653589793::fp64
radians(270::fp64) = 4.71238898038469::fp64
radians(360::fp64) = 6.283185307179586::fp64

# negative: Negative degree values
radians(-90::fp64) = -1.5707963267948966::fp64
radians(-180::fp64) = -3.141592653589793::fp64
radians(-360::fp64) = -6.283185307179586::fp64

# null_handling: Examples with null as input
radians(null::fp64) = null::fp64

# types: Examples with different numeric types
radians(90::fp32) = 1.5707963267948966::fp32
radians(180::fp32) = 3.141592653589793::fp32

# edge_cases: Special floating point values
radians(inf::fp64) = inf::fp64
radians(-inf::fp64) = -inf::fp64
radians(nan::fp64) = nan::fp64

# precision: Various angle values
radians(45::fp64) = 0.7853981633974483::fp64
radians(30::fp64) = 0.5235987755982988::fp64
radians(60::fp64) = 1.0471975511965976::fp64
radians(1::fp64) = 0.017453292519943295::fp64