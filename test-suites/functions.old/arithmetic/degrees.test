### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic radian to degree conversion
degrees(0::fp64) = 0::fp64
degrees(1.5707963267948966::fp64) = 90::fp64
degrees(3.141592653589793::fp64) = 180::fp64
degrees(4.71238898038469::fp64) = 270::fp64
degrees(6.283185307179586::fp64) = 360::fp64

# negative: Negative radian values
degrees(-1.5707963267948966::fp64) = -90::fp64
degrees(-3.141592653589793::fp64) = -180::fp64
degrees(-6.283185307179586::fp64) = -360::fp64

# null_handling: Examples with null as input
degrees(null::fp64) = null::fp64

# types: Examples with different numeric types
degrees(1.5707963267948966::fp32) = 90::fp32
degrees(3.141592653589793::fp32) = 180::fp32

# edge_cases: Special floating point values
degrees(inf::fp64) = inf::fp64
degrees(-inf::fp64) = -inf::fp64
degrees(nan::fp64) = nan::fp64

# precision: Various radian values
degrees(0.7853981633974483::fp64) = 45::fp64
degrees(0.5235987755982988::fp64) = 30::fp64
degrees(1.0471975511965976::fp64) = 60::fp64
degrees(0.017453292519943295::fp64) = 1::fp64