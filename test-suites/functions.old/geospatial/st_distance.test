### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_geospatial.yaml'

# basic: Basic distance calculations between points
st_distance(st_point(0.0::fp64, 0.0::fp64), st_point(3.0::fp64, 4.0::fp64)) = 5.0::fp64
st_distance(st_point(0.0::fp64, 0.0::fp64), st_point(1.0::fp64, 1.0::fp64)) = 1.4142135623730951::fp64
st_distance(st_point(1.0::fp64, 1.0::fp64), st_point(1.0::fp64, 1.0::fp64)) = 0.0::fp64

# negative_coords: Distance with negative coordinates
st_distance(st_point(-1.0::fp64, -1.0::fp64), st_point(1.0::fp64, 1.0::fp64)) = 2.8284271247461903::fp64
st_distance(st_point(-3.0::fp64, 0.0::fp64), st_point(3.0::fp64, 0.0::fp64)) = 6.0::fp64

# null_handling: Distance with null geometries
st_distance(null::geometry, st_point(1.0::fp64, 1.0::fp64)) = null::fp64
st_distance(st_point(1.0::fp64, 1.0::fp64), null::geometry) = null::fp64

# large_distances: Large distance calculations
st_distance(st_point(0.0::fp64, 0.0::fp64), st_point(100.0::fp64, 100.0::fp64)) = 141.4213562373095::fp64
st_distance(st_point(-50.0::fp64, -50.0::fp64), st_point(50.0::fp64, 50.0::fp64)) = 141.4213562373095::fp64

# precision: High precision distance calculations
st_distance(st_point(0.0::fp64, 0.0::fp64), st_point(0.1::fp64, 0.1::fp64)) = 0.14142135623730951::fp64