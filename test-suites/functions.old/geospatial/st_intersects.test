### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_geospatial.yaml'

# basic: Basic intersection checks
st_intersects(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_polygon([[5.0, 5.0], [15.0, 5.0], [15.0, 15.0], [5.0, 15.0], [5.0, 5.0]]::list<point>)) = true::bool
st_intersects(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_polygon([[20.0, 20.0], [30.0, 20.0], [30.0, 30.0], [20.0, 30.0], [20.0, 20.0]]::list<point>)) = false::bool

# point_polygon: Point and polygon intersection
st_intersects(st_point(5.0::fp64, 5.0::fp64), st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>)) = true::bool
st_intersects(st_point(15.0::fp64, 15.0::fp64), st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>)) = false::bool

# touching: Geometries that touch at boundary
st_intersects(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_polygon([[10.0, 0.0], [20.0, 0.0], [20.0, 10.0], [10.0, 10.0], [10.0, 0.0]]::list<point>)) = true::bool

# null_handling: Intersection with null geometries
st_intersects(null::geometry, st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>)) = null::bool
st_intersects(st_point(5.0::fp64, 5.0::fp64), null::geometry) = null::bool

# line_intersection: Line intersections
st_intersects(st_line([[0.0, 0.0], [10.0, 10.0]]::list<point>), st_line([[0.0, 10.0], [10.0, 0.0]]::list<point>)) = true::bool
st_intersects(st_line([[0.0, 0.0], [10.0, 0.0]]::list<point>), st_line([[0.0, 5.0], [10.0, 5.0]]::list<point>)) = false::bool