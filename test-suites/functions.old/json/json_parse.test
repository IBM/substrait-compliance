### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_json.yaml'

# basic: Basic JSON parsing
json_parse('{"name": "John", "age": 30}'::str) = {"name": "John", "age": 30}::json
json_parse('[1, 2, 3, 4, 5]'::str) = [1, 2, 3, 4, 5]::json
json_parse('"hello"'::str) = "hello"::json
json_parse('123'::str) = 123::json
json_parse('true'::str) = true::json

# nested: Nested JSON structures
json_parse('{"person": {"name": "Jane", "age": 25}}'::str) = {"person": {"name": "Jane", "age": 25}}::json
json_parse('{"data": {"values": [1, 2, 3]}}'::str) = {"data": {"values": [1, 2, 3]}}::json

# array: Complex arrays
json_parse('[{"id": 1, "name": "A"}, {"id": 2, "name": "B"}]'::str) = [{"id": 1, "name": "A"}, {"id": 2, "name": "B"}]::json

# null_handling: Null values
json_parse('null'::str) = null::json
json_parse('{"value": null}'::str) = {"value": null}::json
json_parse(null::str) = null::json

# invalid: Invalid JSON (should error or return null)
json_parse('invalid json'::str) [error_handling:ERROR] = <!ERROR>
json_parse('{"unclosed": '::str) [error_handling:ERROR] = <!ERROR>

# whitespace: JSON with whitespace
json_parse('  {"name": "John"}  '::str) = {"name": "John"}::json
json_parse('\n{\n  "key": "value"\n}\n'::str) = {"key": "value"}::json