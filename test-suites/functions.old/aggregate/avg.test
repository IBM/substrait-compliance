### SUBSTRAIT_AGGREGATE_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_aggregate_generic.yaml'

# basic: Basic examples without any special cases
avg((1, 2, 3, 4, 5)::i32) = 3.0::fp64
avg((10, 20, 30, 40)::i64) = 25.0::fp64
avg((2.5, 5.0, 7.5, 10.0)::fp32) = 6.25::fp64
avg((1.5, 2.5, 3.5, 4.5, 5.5)::fp64) = 3.5::fp64

# negative: Examples with negative numbers
avg((-10, -20, -30)::i32) = -20.0::fp64
avg((10, -10, 20, -20)::i32) = 0.0::fp64
avg((-5.5, -2.5, -1.0)::fp64) = -3.0::fp64

# null_handling: Examples with null as input or output
avg((1, Null, 3, Null, 5)::i32) = 3.0::fp64
avg((Null, Null, Null)::i32) = Null::fp64
avg(()::i32) = Null::fp64
avg((10, Null, 20, 30)::i32) = 20.0::fp64

# floating_exception: Examples demonstrating exceptional floating point cases
avg((1.5e+308, 1.5e+308)::fp64) = inf::fp64
avg((-1.5e+308, -1.5e+308)::fp64) = -inf::fp64
avg((inf, 100.0, 200.0)::fp64) = inf::fp64
avg((-inf, 100.0, 200.0)::fp64) = -inf::fp64

# precision: Examples demonstrating precision handling
avg((1, 2)::i32) = 1.5::fp64
avg((1, 2, 3)::i32) = 2.0::fp64
avg((1, 1, 1, 2)::i32) = 1.25::fp64

# types: Examples demonstrating behavior of different data types
avg((1::i8, 2::i8, 3::i8))::i8 = 2.0::fp64
avg((100::i16, 200::i16, 300::i16))::i16 = 200.0::fp64
avg((1.5::fp32, 2.5::fp32, 3.5::fp32))::fp32 = 2.5::fp64