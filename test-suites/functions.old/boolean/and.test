### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_boolean.yaml'

# basic: Basic examples without any special cases
and(true::bool, true::bool) = true::bool
and(true::bool, false::bool) = false::bool
and(false::bool, false::bool) = false::bool
and(false::bool, true::bool) = false::bool

# null_input: Examples with null as input
and(true::bool, null::bool) = null::bool
and(null::bool, true::bool) = null::bool
and(false::bool, null::bool) = false::bool
and(null::bool, false::bool) = false::bool
and(null::bool, null::bool) = null::bool

# multiple_operands: Examples with multiple AND operations
and(and(true::bool, true::bool), true::bool) = true::bool
and(and(true::bool, true::bool), false::bool) = false::bool
and(and(true::bool, false::bool), true::bool) = false::bool
and(and(false::bool, false::bool), false::bool) = false::bool

# chained_with_comparisons: Examples combining AND with comparisons
and(equal(5::i32, 5::i32), equal(10::i32, 10::i32)) = true::bool
and(equal(5::i32, 5::i32), equal(10::i32, 20::i32)) = false::bool
and(gt(10::i32, 5::i32), lt(5::i32, 10::i32)) = true::bool
and(gt(10::i32, 5::i32), lt(10::i32, 5::i32)) = false::bool

# short_circuit: Examples demonstrating short-circuit evaluation
and(false::bool, is_null(null::i32)) = false::bool
and(false::bool, equal(1::i32, 1::i32)) = false::bool

# complex_expressions: Examples with complex boolean expressions
and(or(true::bool, false::bool), or(true::bool, false::bool)) = true::bool
and(or(true::bool, false::bool), or(false::bool, false::bool)) = false::bool
and(not(false::bool), not(false::bool)) = true::bool
and(not(true::bool), not(false::bool)) = false::bool

# with_null_comparisons: Examples combining AND with null checks
and(is_not_null(5::i32), is_not_null(10::i32)) = true::bool
and(is_not_null(5::i32), is_null(null::i32)) = false::bool
and(is_null(null::i32), is_null(null::i32)) = true::bool
