### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_cast.yaml'

# integer_to_integer: Cast between integer types
cast(100::i8, i16) = 100::i16
cast(1000::i16, i32) = 1000::i32
cast(100000::i32, i64) = 100000::i64
cast(127::i8, i64) = 127::i64

# integer_downcast: Downcast integer types
cast(100::i16, i8) = 100::i8
cast(1000::i32, i16) = 1000::i16
cast(100000::i64, i32) = 100000::i32

# integer_to_float: Cast integer to floating point
cast(42::i8, fp32) = 42.0::fp32
cast(1000::i16, fp32) = 1000.0::fp32
cast(100000::i32, fp64) = 100000.0::fp64
cast(123456789::i64, fp64) = 123456789.0::fp64

# float_to_integer: Cast floating point to integer (truncation)
cast(42.7::fp32, i32) = 42::i32
cast(42.3::fp32, i32) = 42::i32
cast(123.456::fp64, i64) = 123::i64
cast(-42.7::fp64, i32) = -42::i32

# float_to_float: Cast between floating point types
cast(3.14::fp32, fp64) = 3.140000104904175::fp64
cast(3.14159265358979::fp64, fp32) = 3.1415927410125732::fp32

# string_to_integer: Cast string to integer
cast('42'::str, i32) = 42::i32
cast('1000'::str, i64) = 1000::i64
cast('-123'::str, i32) = -123::i32

# string_to_float: Cast string to floating point
cast('3.14'::str, fp32) = 3.14::fp32
cast('123.456'::str, fp64) = 123.456::fp64
cast('-42.5'::str, fp64) = -42.5::fp64

# integer_to_string: Cast integer to string
cast(42::i32, str) = '42'::str
cast(1000::i64, str) = '1000'::str
cast(-123::i32, str) = '-123'::str

# float_to_string: Cast floating point to string
cast(3.14::fp32, str) = '3.14'::str
cast(123.456::fp64, str) = '123.456'::str

# boolean_to_integer: Cast boolean to integer
cast(true::bool, i32) = 1::i32
cast(false::bool, i32) = 0::i32

# integer_to_boolean: Cast integer to boolean
cast(1::i32, bool) = true::bool
cast(0::i32, bool) = false::bool
cast(42::i32, bool) = true::bool

# boolean_to_string: Cast boolean to string
cast(true::bool, str) = 'true'::str
cast(false::bool, str) = 'false'::str

# string_to_boolean: Cast string to boolean
cast('true'::str, bool) = true::bool
cast('false'::str, bool) = false::bool
cast('TRUE'::str, bool) = true::bool
cast('FALSE'::str, bool) = false::bool

# null_handling: Examples with null values
cast(null::i32, i64) = null::i64
cast(null::str, i32) = null::i32
cast(null::fp32, fp64) = null::fp64

# overflow: Examples demonstrating overflow behavior
cast(128::i16, i8) [overflow:ERROR] = <!ERROR>
cast(-129::i16, i8) [overflow:ERROR] = <!ERROR>
cast(32768::i32, i16) [overflow:ERROR] = <!ERROR>
cast(128::i16, i8) [overflow:SATURATE] = 127::i8
cast(-129::i16, i8) [overflow:SATURATE] = -128::i8