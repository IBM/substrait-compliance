### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_set.yaml'

# basic: Basic set difference (except)
except([1, 2, 3, 4]::list<i32>, [3, 4, 5, 6]::list<i32>) = [1, 2]::list<i32>
except(['a', 'b', 'c', 'd']::list<str>, ['c', 'd', 'e']::list<str>) = ['a', 'b']::list<str>
except([1, 2, 3]::list<i32>, [4, 5, 6]::list<i32>) = [1, 2, 3]::list<i32>

# empty: Except with empty sets
except([1, 2, 3]::list<i32>, []::list<i32>) = [1, 2, 3]::list<i32>
except([]::list<i32>, [1, 2, 3]::list<i32>) = []::list<i32>
except([]::list<i32>, []::list<i32>) = []::list<i32>

# duplicates: Except with duplicates
except([1, 1, 2, 2, 3]::list<i32>, [2, 2, 3, 3]::list<i32>) = [1]::list<i32>
except(['a', 'a', 'b', 'b', 'c']::list<str>, ['b', 'c', 'c']::list<str>) = ['a']::list<str>

# null_handling: Except with null elements
except([1, null, 3, 4]::list<i32>, [3, 4]::list<i32>) = [1, null]::list<i32>
except([1, 2, 3]::list<i32>, [null, 3]::list<i32>) = [1, 2]::list<i32>
except(null::list<i32>, [1, 2, 3]::list<i32>) = null::list<i32>
except([1, 2, 3]::list<i32>, null::list<i32>) = null::list<i32>

# types: Different data types
except([1.5, 2.5, 3.5, 4.5]::list<fp64>, [3.5, 4.5, 5.5]::list<fp64>) = [1.5, 2.5]::list<fp64>
except([true, false]::list<bool>, [false]::list<bool>) = [true]::list<bool>

# identical: Except of identical sets
except([1, 2, 3]::list<i32>, [1, 2, 3]::list<i32>) = []::list<i32>
except(['a', 'b']::list<str>, ['a', 'b']::list<str>) = []::list<str>