### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_conditional.yaml'

# basic: Basic IF-THEN-ELSE expressions
if_then_else(true::bool, 1::i32, 2::i32) = 1::i32
if_then_else(false::bool, 1::i32, 2::i32) = 2::i32
if_then_else(5::i32 > 3::i32, 'yes'::str, 'no'::str) = 'yes'::str
if_then_else(5::i32 < 3::i32, 'yes'::str, 'no'::str) = 'no'::str

# null_handling: IF with null values
if_then_else(null::bool, 1::i32, 2::i32) = 2::i32
if_then_else(true::bool, null::i32, 2::i32) = null::i32
if_then_else(false::bool, 1::i32, null::i32) = null::i32

# types: Different data types
if_then_else(true::bool, 1.5::fp64, 2.5::fp64) = 1.5::fp64
if_then_else(false::bool, 100::i64, 200::i64) = 200::i64
if_then_else(true::bool, 'true'::str, 'false'::str) = 'true'::str
if_then_else(false::bool, true::bool, false::bool) = false::bool

# nested: Nested IF expressions
if_then_else(true::bool, if_then_else(true::bool, 1::i32, 2::i32), 3::i32) = 1::i32
if_then_else(false::bool, 1::i32, if_then_else(true::bool, 2::i32, 3::i32)) = 2::i32
if_then_else(true::bool, if_then_else(false::bool, 1::i32, 2::i32), 3::i32) = 2::i32

# comparisons: Using comparisons as conditions
if_then_else(10::i32 = 10::i32, 'equal'::str, 'not equal'::str) = 'equal'::str
if_then_else(10::i32 != 10::i32, 'not equal'::str, 'equal'::str) = 'equal'::str
if_then_else(10::i32 > 5::i32, 'greater'::str, 'not greater'::str) = 'greater'::str
if_then_else(10::i32 < 5::i32, 'less'::str, 'not less'::str) = 'not less'::str