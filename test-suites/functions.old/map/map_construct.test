### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_map.yaml'

# basic: Basic map construction
map_construct('key1'::str, 'value1'::str, 'key2'::str, 'value2'::str) = {'key1': 'value1', 'key2': 'value2'}::map<str, str>
map_construct(1::i32, 'one'::str, 2::i32, 'two'::str, 3::i32, 'three'::str) = {1: 'one', 2: 'two', 3: 'three'}::map<i32, str>
map_construct('a'::str, 100::i32, 'b'::str, 200::i32) = {'a': 100, 'b': 200}::map<str, i32>

# empty: Empty map construction
map_construct() = {}::map<str, str>

# single_entry: Single entry maps
map_construct('key'::str, 'value'::str) = {'key': 'value'}::map<str, str>
map_construct(1::i32, 100::i32) = {1: 100}::map<i32, i32>

# null_handling: Maps with null values
map_construct('key1'::str, 'value1'::str, 'key2'::str, null::str) = {'key1': 'value1', 'key2': null}::map<str, str>
map_construct(1::i32, null::str, 2::i32, 'two'::str) = {1: null, 2: 'two'}::map<i32, str>

# types: Different data types
map_construct(1::i64, 1.5::fp64, 2::i64, 2.5::fp64) = {1: 1.5, 2: 2.5}::map<i64, fp64>
map_construct('flag1'::str, true::bool, 'flag2'::str, false::bool) = {'flag1': true, 'flag2': false}::map<str, bool>

# complex: Maps with complex values
map_construct('list1'::str, [1, 2, 3]::list<i32>, 'list2'::str, [4, 5, 6]::list<i32>) = {'list1': [1, 2, 3], 'list2': [4, 5, 6]}::map<str, list<i32>>