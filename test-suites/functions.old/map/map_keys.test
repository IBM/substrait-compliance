### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_map.yaml'

# basic: Basic map keys extraction
map_keys({'key1': 'value1', 'key2': 'value2', 'key3': 'value3'}::map<str, str>) = ['key1', 'key2', 'key3']::list<str>
map_keys({1: 'one', 2: 'two', 3: 'three'}::map<i32, str>) = [1, 2, 3]::list<i32>
map_keys({'a': 100, 'b': 200}::map<str, i32>) = ['a', 'b']::list<str>

# empty: Empty map
map_keys({}::map<str, str>) = []::list<str>

# single_entry: Single entry map
map_keys({'key': 'value'}::map<str, str>) = ['key']::list<str>

# null_handling: Maps with null values (keys are still returned)
map_keys({'key1': 'value1', 'key2': null}::map<str, str>) = ['key1', 'key2']::list<str>
map_keys(null::map<str, str>) = null::list<str>

# types: Different key types
map_keys({1: 1.5, 2: 2.5, 3: 3.5}::map<i64, fp64>) = [1, 2, 3]::list<i64>
map_keys({100: true, 200: false}::map<i32, bool>) = [100, 200]::list<i32>