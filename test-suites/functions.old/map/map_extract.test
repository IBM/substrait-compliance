### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_map.yaml'

# basic: Basic map value extraction
map_extract({'key1': 'value1', 'key2': 'value2'}::map<str, str>, 'key1'::str) = 'value1'::str
map_extract({'key1': 'value1', 'key2': 'value2'}::map<str, str>, 'key2'::str) = 'value2'::str
map_extract({1: 'one', 2: 'two', 3: 'three'}::map<i32, str>, 2::i32) = 'two'::str
map_extract({'a': 100, 'b': 200}::map<str, i32>, 'a'::str) = 100::i32

# missing_key: Extracting non-existent keys
map_extract({'key1': 'value1'}::map<str, str>, 'key2'::str) = null::str
map_extract({1: 'one', 2: 'two'}::map<i32, str>, 3::i32) = null::str

# null_handling: Maps with null values
map_extract({'key1': 'value1', 'key2': null}::map<str, str>, 'key2'::str) = null::str
map_extract(null::map<str, str>, 'key'::str) = null::str

# types: Different data types
map_extract({1: 1.5, 2: 2.5}::map<i64, fp64>, 1::i64) = 1.5::fp64
map_extract({'flag1': true, 'flag2': false}::map<str, bool>, 'flag1'::str) = true::bool

# complex: Maps with complex values
map_extract({'list1': [1, 2, 3], 'list2': [4, 5, 6]}::map<str, list<i32>>, 'list1'::str) = [1, 2, 3]::list<i32>