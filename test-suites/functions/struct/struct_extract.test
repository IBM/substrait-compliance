### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_struct.yaml'

# basic: Basic struct field extraction
struct_extract({name: 'John', age: 30}::struct<name:str, age:i32>, 'name') = 'John'::str
struct_extract({name: 'John', age: 30}::struct<name:str, age:i32>, 'age') = 30::i32
struct_extract({x: 10, y: 20}::struct<x:i32, y:i32>, 'x') = 10::i32
struct_extract({x: 10, y: 20}::struct<x:i32, y:i32>, 'y') = 20::i32

# null_handling: Extracting null fields
struct_extract({name: 'Bob', age: null}::struct<name:str, age:i32>, 'age') = null::i32
struct_extract(null::struct<name:str, age:i32>, 'name') = null::str

# nested: Extracting from nested structs
struct_extract({person: {name: 'Jane', age: 25}, city: 'NYC'}::struct<person:struct<name:str, age:i32>, city:str>, 'person') = {name: 'Jane', age: 25}::struct<name:str, age:i32>
struct_extract({person: {name: 'Jane', age: 25}, city: 'NYC'}::struct<person:struct<name:str, age:i32>, city:str>, 'city') = 'NYC'::str

# types: Different data types
struct_extract({id: 1, price: 99.99, available: true}::struct<id:i32, price:fp64, available:bool>, 'price') = 99.99::fp64
struct_extract({id: 1, price: 99.99, available: true}::struct<id:i32, price:fp64, available:bool>, 'available') = true::bool

# complex: Extracting arrays from structs
struct_extract({name: 'Team', members: [1, 2, 3]}::struct<name:str, members:list<i32>>, 'members') = [1, 2, 3]::list<i32>