### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_struct.yaml'

# basic: Basic struct field extraction
struct_extract({name: 'John', age: 30}::struct<name:str, age:i32>, 'name') = 'John'::str
struct_extract({name: 'John', age: 30}::struct<name:str, age:i32>, 'age') = 30::i32
struct_extract({x: 10, y: 20}::struct<x:i32, y:i32>, 'x') = 10::i32
struct_extract({x: 10, y: 20}::struct<x:i32, y:i32>, 'y') = 20::i32

# null_handling: Extracting null fields
struct_extract({name: 'Bob', age: null}::struct<name:str, age:i32>, 'age') = null::i32
struct_extract(null::struct<name:str, age:i32>, 'name') = null::str

# nested: Extracting from nested structs
struct_extract({person: {name: 'Jane', age: 25}, city: 'NYC'}::struct<person:struct<name:str, age:i32>, city:str>, 'person') = {name: 'Jane', age: 25}::struct<name:str, age:i32>
struct_extract({person: {name: 'Jane', age: 25}, city: 'NYC'}::struct<person:struct<name:str, age:i32>, city:str>, 'city') = 'NYC'::str

# types: Different data types
struct_extract({id: 1, price: 99.99, available: true}::struct<id:i32, price:fp64, available:bool>, 'price') = 99.99::fp64
struct_extract({id: 1, price: 99.99, available: true}::struct<id:i32, price:fp64, available:bool>, 'available') = true::bool

# complex: Extracting arrays from structs
struct_extract({name: 'Team', members: [1, 2, 3]}::struct<name:str, members:list<i32>>, 'members') = [1, 2, 3]::list<i32>

# edge_cases: Boundary values and extreme inputs
struct_extract({big_int: 9223372036854775807}::struct<big_int:i64>, 'big_int') = 9223372036854775807::i64

# null_handling_extended: Extended null handling scenarios
struct_extract({name: null, age: null}::struct<name:str, age:i32>, 'name') = null::str
struct_extract({name: null, age: null}::struct<name:str, age:i32>, 'age') = null::i32
struct_extract({data: null}::struct<data:list<i32>>, 'data') = null::list<i32>

# zero_handling: Zero and negative zero handling
struct_extract({timestamp: 2023-01-01T00:00:00}::struct<timestamp:timestamp>, 'timestamp') = 2023-01-01T00:00:00::timestamp

# negative_values: Negative number handling
struct_extract({date_field: 2023-01-01}::struct<date_field:date>, 'date_field') = 2023-01-01::date

# type_coverage: Various data type coverage
struct_extract({value: 42}::struct<value:i32>, 'value') = 42::i32
struct_extract({a: 1, b: 2, c: 3, d: 4, e: 5}::struct<a:i32, b:i32, c:i32, d:i32, e:i32>, 'c') = 3::i32
struct_extract({a: 1, b: 2, c: 3, d: 4, e: 5}::struct<a:i32, b:i32, c:i32, d:i32, e:i32>, 'a') = 1::i32
struct_extract({a: 1, b: 2, c: 3, d: 4, e: 5}::struct<a:i32, b:i32, c:i32, d:i32, e:i32>, 'e') = 5::i32
struct_extract({field123: 100}::struct<field123:i32>, 'field123') = 100::i32
struct_extract({small_int: 100}::struct<small_int:i16>, 'small_int') = 100::i16

# additional_coverage: Additional test coverage
struct_extract({name: 'Test'}::struct<name:str>, 'name') = 'Test'::str
struct_extract({flag: false}::struct<flag:bool>, 'flag') = false::bool
struct_extract({field_name: 'value'}::struct<field_name:str>, 'field_name') = 'value'::str
struct_extract({first_name: 'Alice', last_name: 'Smith'}::struct<first_name:str, last_name:str>, 'first_name') = 'Alice'::str
struct_extract({outer: {middle: {inner: 'deep'}}}::struct<outer:struct<middle:struct<inner:str>>>, 'outer') = {middle: {inner: 'deep'}}::struct<middle:struct<inner:str>>
struct_extract({level1: {level2: {level3: 999}}}::struct<level1:struct<level2:struct<level3:i32>>>, 'level1') = {level2: {level3: 999}}::struct<level2:struct<level3:i32>>
struct_extract({binary_data: 0x48656C6C6F}::struct<binary_data:binary>, 'binary_data') = 0x48656C6C6F::binary

