st_distance(st_point(0.0::fp64, inf::fp64), st_point(0.0::fp64, 0.0::fp64)) = inf::fp64
st_distance(st_point(-inf::fp64, 0.0::fp64), st_point(0.0::fp64, 0.0::fp64)) = inf::fp64
st_distance(st_point(nan::fp64, 0.0::fp64), st_point(0.0::fp64, 0.0::fp64)) = nan::fp64

