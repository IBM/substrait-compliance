# basic: Basic containment checks
st_contains(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_point(5.0::fp64, 5.0::fp64)) = true::bool
st_contains(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_point(15.0::fp64, 15.0::fp64)) = false::bool
st_contains(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_point(0.0::fp64, 0.0::fp64)) = true::bool

# boundary: Points on boundary
st_contains(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_point(10.0::fp64, 5.0::fp64)) = true::bool
st_contains(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), st_point(5.0::fp64, 0.0::fp64)) = true::bool

# null_handling: Containment with null geometries
st_contains(null::geometry, st_point(5.0::fp64, 5.0::fp64)) = null::bool
st_contains(st_polygon([[0.0, 0.0], [10.0, 0.0], [10.0, 10.0], [0.0, 10.0], [0.0, 0.0]]::list<point>), null::geometry) = null::bool

# negative_coords: Polygons with negative coordinates
st_contains(st_polygon([[-10.0, -10.0], [10.0, -10.0], [10.0, 10.0], [-10.0, 10.0], [-10.0, -10.0]]::list<point>), st_point(0.0::fp64, 0.0::fp64)) = true::bool
st_contains(st_polygon([[-10.0, -10.0], [10.0, -10.0], [10.0, 10.0], [-10.0, 10.0], [-10.0, -10.0]]::list<point>), st_point(-5.0::fp64, -5.0::fp64)) = true::bool
st_contains(st_polygon([[-10.0, -10.0], [10.0, -10.0], [10.0, 10.0], [-10.0, 10.0], [-10.0, -10.0]]::list<point>), st_point(15.0::fp64, 15.0::fp64)) = false::bool

