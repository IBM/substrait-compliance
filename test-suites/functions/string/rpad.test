### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_string.yaml'

# basic: Basic examples without any special cases
rpad('abcdef'::str, 10::i32, ' '::str) = 'abcdef    '::str
rpad('abcdef    '::str, 20::i32, '1'::str) = 'abcdef    1111111111'::str
rpad('    abcdef'::str, 20::i32, '1'::str) = '    abcdef1111111111'::str
rpad('abcdef'::str, 6::i32, ' '::str) = 'abcdef'::str
rpad('abcdef'::str, 20::i32, 'aabb'::str) = 'abcdefaabbaabbaabbaa'::str
rpad('abcdef'::str, 4::i32, ' '::str) = 'abcd'::str
rpad('abcdef'::str, -1::i32, ' '::str) = ''::str
rpad(null::str, 4::i32, ' '::str) = null::str
rpad('abcdef'::str, 10::i32, null::str) = null::str


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# null_handling_extended: Extended null handling scenarios
rpad('abc'::str, null::i32, 'x'::str) = null::str
rpad(null::str, null::i32, 'x'::str) = null::str
rpad(null::str, 5::i32, null::str) = null::str

# zero_handling: Zero and negative zero handling
rpad('abc'::str, 0::i32, 'x'::str) = ''::str

# empty_values: Empty strings and collections
rpad(''::str, 5::i32, 'x'::str) = 'xxxxx'::str

# type_coverage: Various data type coverage
rpad('abc'::str, 1::i32, 'x'::str) = 'a'::str
rpad('abc'::str, 2::i32, 'x'::str) = 'ab'::str
rpad('abc'::str, 8::i32, 'xy'::str) = 'abcxyxyx'::str
rpad('ab'::str, 9::i32, '123'::str) = 'ab1231231'::str
rpad('x'::str, 7::i32, 'abcd'::str) = 'xabcdab'::str
rpad('😀'::str, 5::i32, '✓'::str) = '😀✓✓✓✓'::str
rpad('test'::str, 8::i32, '中'::str) = 'test中中中中'::str

# unicode_handling: Unicode and special characters
rpad('abc'::str, 10::i32, '🔥'::str) = 'abc🔥🔥🔥🔥🔥🔥🔥'::str

