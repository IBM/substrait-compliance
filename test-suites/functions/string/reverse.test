### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_string.yaml'

# basic: Basic examples without any special cases
reverse('abc'::str) = 'cba'::str
reverse('aBc'::str) = 'cBa'::str
reverse('   123'::str) = '321   '::str
reverse(''::str) = ''::str

# null_input: Examples with null as input
reverse(null::str) = null::str

# unicode: Examples with unicode characters as input
reverse('ГҰГҰГЈГЈa'::str) = 'aГЈГЈГҰГҰ'::str
reverse('рҹҳ”рҹҳ„'::str) = 'рҹҳ„рҹҳ”'::str

# unicode_handling: Unicode and special characters
reverse('cafГ©'::str) = 'Г©fac'::str
reverse('naГҜve'::str) = 'evГҜan'::str
reverse('Helloдё–з•Ң'::str) = 'з•Ңдё–olleH'::str
reverse('testрҹҺү123'::str) = '321рҹҺүtset'::str
reverse('cafГ©123вҳ•'::str) = 'вҳ•321Г©fac'::str

# whitespace_handling: Whitespace and control characters
reverse('  '::str) = '  '::str
reverse('\n\t\r'::str) = '\r\t\n'::str
reverse('abc\ndef'::str) = 'fed\ncba'::str
reverse('hello\tworld'::str) = 'dlrow\tolleh'::str

# additional_coverage: Additional test coverage
reverse('a'::str) = 'a'::str
reverse('Z'::str) = 'Z'::str
reverse('5'::str) = '5'::str
reverse('123'::str) = '321'::str
reverse('!@#$%'::str) = '%$#@!'::str
reverse('123abc!@#'::str) = '#@!cba321'::str
reverse('Hello World'::str) = 'dlroW olleH'::str
reverse('Test123'::str) = '321tseT'::str
reverse('ABC-def_123'::str) = '321_fed-CBA'::str
reverse('rГ©sumГ©'::str) = 'Г©musГ©r'::str
reverse('e\u0301'::str) = '\u0301e'::str
reverse('a\u0300b'::str) = 'b\u0300a'::str
reverse('aрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұb'::str) = 'bрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұa'::str
reverse('рҹҸҙу Ғ§у Ғўу ҒҘу Ғ®у Ғ§у Ғҝtest'::str) = 'tsetрҹҸҙу Ғ§у Ғўу ҒҘу Ғ®у Ғ§у Ғҝ'::str

