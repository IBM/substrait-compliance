### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_string.yaml'

# basic: Basic examples without any special cases
rtrim('abc'::str, ' '::str) = 'abc'::str
rtrim('   abc'::str, ' '::str) = '   abc'::str
rtrim('abc   '::str, ' '::str) = 'abc'::str
rtrim('   abc   '::str, ' '::str) = '   abc'::str
rtrim(''::str, ' '::str) = ''::str
rtrim(' '::str, ' '::str) = ''::str
rtrim(null::str, ' '::str) = null::str

# two_inputs: Examples with character input to trim off
rtrim('aaaaabccccc'::str, 'c'::str) [spaces_only:FALSE] = 'aaaaab'::str
rtrim('abcabcdef'::str, 'def'::str) [spaces_only:FALSE] = 'abcabc'::str
rtrim('defabccba'::str, 'abc'::str) [spaces_only:FALSE] = 'def'::str

# null_handling_extended: Extended null handling scenarios
rtrim('abc'::str, null::str) = null::str
rtrim(null::str, null::str) = null::str

# empty_values: Empty strings and collections
rtrim('abc'::str, ''::str) [spaces_only:FALSE] = 'abc'::str
rtrim('   abc   '::str, ''::str) [spaces_only:FALSE] = '   abc   '::str
rtrim('ccccc'::str, 'c'::str) [spaces_only:FALSE] = ''::str
rtrim('abcdefghij'::str, 'jihgfedcba'::str) [spaces_only:FALSE] = ''::str
rtrim('     '::str, ' '::str) [spaces_only:FALSE] = ''::str
rtrim('xyzzyx'::str, 'xyz'::str) [spaces_only:FALSE] = ''::str
rtrim('test'::str, 'testing'::str) [spaces_only:FALSE] = ''::str
rtrim('ab'::str, 'abcdefghij'::str) [spaces_only:FALSE] = ''::str

# unicode_handling: Unicode and special characters
rtrim('café☕'::str, '☕'::str) [spaces_only:FALSE] = 'café'::str

# whitespace_handling: Whitespace and control characters
rtrim('hello world  '::str, ' dlorw'::str) [spaces_only:FALSE] = 'he'::str
rtrim('test\t\t'::str, '\t'::str) [spaces_only:FALSE] = 'test'::str
rtrim('line\n\n'::str, '\n'::str) [spaces_only:FALSE] = 'line'::str
rtrim('text\r\n'::str, '\r\n'::str) [spaces_only:FALSE] = 'text'::str

# additional_coverage: Additional test coverage
rtrim('test123'::str, '321'::str) [spaces_only:FALSE] = 'test'::str
rtrim('hello🌍🌎🌏'::str, '🌍🌎🌏'::str) [spaces_only:FALSE] = 'hello'::str
rtrim('test文字'::str, '字文'::str) [spaces_only:FALSE] = 'test'::str

