### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_string.yaml'

# basic: Basic examples without any special cases
right('abcdef'::str, 2::i32) = 'ef'::str
right('abcdef'::str, 6::i32) = 'abcdef'::str
right('abcdef'::str, 10::i32) = 'abcdef'::str
right('  abcdef  abcdef'::str, 10::i32) = 'ef  abcdef'::str
right(null::str, 10::i32) = null::str
right('abcdef'::str, null::i32) = null::str

# unicode: Examples with unicode characters as input
right('ææããa'::str, 2::i32) = 'ãa'::str
right('😔😄😔😄'::str, 2::i32) = '😔😄'::str


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
right('abcdef'::str, 2147483647::i32) = 'abcdef'::str
right('test'::str, -2147483648::i32) = ''::str

# null_handling_extended: Extended null handling scenarios
right('null\0byte'::str, 4::i32) = 'byte'::str

# zero_handling: Zero and negative zero handling
right('abcdef'::str, 0::i32) = ''::str
right('a'::str, 0::i32) = ''::str

# empty_values: Empty strings and collections
right(''::str, 2::i32) = ''::str
right('abcdef'::str, -1::i32) = ''::str
right('hello'::str, -5::i32) = ''::str

# type_coverage: Various data type coverage
right('a'::str, 1::i32) = 'a'::str
right('abc'::str, 3::i32) = 'abc'::str
right('hello\nworld'::str, 5::i32) = 'world'::str
right('tab\there'::str, 4::i32) = 'here'::str
right('line1\r\nline2'::str, 5::i32) = 'line2'::str
right('mixed😄text'::str, 4::i32) = '😄text'::str
right('مرحبا'::str, 3::i32) = 'حبا'::str
right('こんにちは'::str, 2::i32) = 'ちは'::str
right('👨‍👩‍👧‍👦test'::str, 4::i32) = 'test'::str
right('a̐é̲'::str, 1::i32) = 'é̲'::str
right('hello'::str, 1::i32) = 'o'::str
right('😄'::str, 1::i32) = '😄'::str
right('ab'::str, 1::i32) = 'b'::str

# unicode_handling: Unicode and special characters
right('café'::str, 2::i32) = 'fé'::str

