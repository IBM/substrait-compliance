### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_boolean.yaml'

# basic: Basic examples without any special cases
xor(true::bool, false::bool) = true::bool
xor(true::bool, true::bool) = false::bool
xor(false::bool, false::bool) = false::bool
xor(false::bool, true::bool) = true::bool

# null_input: Examples with null as input
xor(true::bool, null::bool) = null::bool
xor(null::bool, true::bool) = null::bool
xor(false::bool, null::bool) = null::bool
xor(null::bool, false::bool) = null::bool
xor(null::bool, null::bool) = null::bool

# truth_table: Complete XOR truth table
xor(false::bool, false::bool) = false::bool
xor(false::bool, true::bool) = true::bool
xor(true::bool, false::bool) = true::bool
xor(true::bool, true::bool) = false::bool

# multiple_operands: Examples with multiple XOR operations
xor(xor(true::bool, false::bool), false::bool) = true::bool
xor(xor(true::bool, true::bool), true::bool) = true::bool
xor(xor(false::bool, false::bool), false::bool) = false::bool
xor(xor(true::bool, false::bool), true::bool) = false::bool

# with_comparisons: Examples combining XOR with comparisons
xor(equal(5::i32, 5::i32), equal(10::i32, 10::i32)) = false::bool
xor(equal(5::i32, 5::i32), equal(10::i32, 20::i32)) = true::bool
xor(gt(10::i32, 5::i32), lt(5::i32, 10::i32)) = false::bool
xor(gt(10::i32, 5::i32), lt(10::i32, 5::i32)) = true::bool

# complex_expressions: Examples with complex boolean expressions
xor(and(true::bool, true::bool), or(false::bool, false::bool)) = true::bool
xor(and(true::bool, false::bool), or(false::bool, false::bool)) = false::bool
xor(not(true::bool), not(false::bool)) = false::bool
xor(not(true::bool), not(true::bool)) = false::bool

# associativity: Examples demonstrating XOR associativity
xor(xor(true::bool, true::bool), true::bool) = xor(true::bool, xor(true::bool, true::bool))
xor(xor(true::bool, false::bool), false::bool) = xor(true::bool, xor(false::bool, false::bool))

# with_null_checks: Examples combining XOR with null checks
xor(is_null(null::i32), is_not_null(5::i32)) = false::bool
xor(is_null(5::i32), is_not_null(5::i32)) = true::bool
xor(is_null(null::i32), is_null(null::i32)) = false::bool
