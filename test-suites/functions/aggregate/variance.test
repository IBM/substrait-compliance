### SUBSTRAIT_AGGREGATE_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_aggregate_generic.yaml'

# basic: Basic examples without any special cases
variance((1, 2, 3, 4, 5)::i32) = 2.0::fp64
variance((10, 20, 30, 40, 50)::i64) = 200.0::fp64
variance((2.0, 4.0, 6.0, 8.0)::fp64) = 5.0::fp64

# uniform: Examples with uniform values
variance((5, 5, 5, 5)::i32) = 0.0::fp64
variance((10.0, 10.0, 10.0)::fp64) = 0.0::fp64

# negative: Examples with negative numbers
variance((-10, -5, 0, 5, 10)::i32) = 50.0::fp64
variance((-2.5, -1.5, -0.5, 0.5, 1.5, 2.5)::fp64) = 2.9166666666666665::fp64

# null_handling: Examples with null as input or output
variance((1, Null, 3, Null, 5)::i32) = 2.6666666666666665::fp64
variance((Null, Null, Null)::i32) = Null::fp64
variance(()::i32) = Null::fp64
variance((10, Null, 20, 30)::i32) = 66.66666666666667::fp64

# single_value: Examples with single value
variance((42)::i32) = 0.0::fp64
variance((3.14)::fp64) = 0.0::fp64

# types: Examples demonstrating behavior of different data types
variance((1::i8, 2::i8, 3::i8, 4::i8))::i8 = 1.25::fp64
variance((100::i16, 200::i16, 300::i16))::i16 = 6666.666666666667::fp64
variance((1.5::fp32, 2.5::fp32, 3.5::fp32))::fp32 = 0.6666666666666666::fp64