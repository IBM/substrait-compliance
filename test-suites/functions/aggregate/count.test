### SUBSTRAIT_AGGREGATE_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_aggregate_generic.yaml'

# basic: Basic examples without any special cases
count((1, 2, 3, 4, 5)::i32) = 5::i64
count((100, 200, 300)::i64) = 3::i64
count(('a', 'b', 'c', 'd')::str) = 4::i64
count((true, false, true)::bool) = 3::i64
count((1.5, 2.5, 3.5, 4.5)::fp64) = 4::i64

# null_handling: Examples with null as input or output
count((1, Null, 3, Null, 5)::i32) = 3::i64
count((Null, Null, Null)::i32) = 0::i64
count(()::i32) = 0::i64
count((Null)::i32) = 0::i64

# types: Examples demonstrating behavior of different data types
count((1::i8, 2::i8, 3::i8))::i8 = 3::i64
count((1000::i16, 2000::i16, 3000::i16))::i16 = 3::i64
count((1.5::fp32, 2.5::fp32, 3.5::fp32))::fp32 = 3::i64
count(('hello'::str, 'world'::str))::str = 2::i64