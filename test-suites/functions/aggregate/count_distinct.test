### SUBSTRAIT_AGGREGATE_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_aggregate_generic.yaml'

# basic: Basic examples without any special cases
count_distinct((1, 2, 3, 4, 5)::i32) = 5::i64
count_distinct((1, 1, 2, 2, 3)::i32) = 3::i64
count_distinct((100, 200, 100, 300, 200)::i64) = 3::i64
count_distinct(('a', 'b', 'a', 'c', 'b', 'd')::str) = 4::i64
count_distinct((true, false, true, false)::bool) = 2::i64

# null_handling: Examples with null as input or output
count_distinct((1, Null, 2, Null, 3)::i32) = 3::i64
count_distinct((1, 1, Null, Null, 2)::i32) = 2::i64
count_distinct((Null, Null, Null)::i32) = 0::i64
count_distinct(()::i32) = 0::i64

# duplicates: Examples with duplicate values
count_distinct((5, 5, 5, 5, 5)::i32) = 1::i64
count_distinct((1.5, 1.5, 2.5, 2.5, 3.5)::fp64) = 3::i64
count_distinct(('hello', 'hello', 'world', 'world')::str) = 2::i64

# types: Examples demonstrating behavior of different data types
count_distinct((1::i8, 2::i8, 1::i8, 3::i8))::i8 = 3::i64
count_distinct((1.5::fp32, 2.5::fp32, 1.5::fp32))::fp32 = 2::i64