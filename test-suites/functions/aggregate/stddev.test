### SUBSTRAIT_INCLUDE: '/extensions/functions_aggregate_generic.yaml'

# basic: Basic examples without any special cases
stddev((1, 2, 3, 4, 5)::i32) = 1.4142135623730951::fp64
stddev((10, 20, 30, 40, 50)::i64) = 14.142135623730951::fp64
stddev((2.0, 4.0, 6.0, 8.0)::fp64) = 2.23606797749979::fp64

# uniform: Examples with uniform values
stddev((5, 5, 5, 5)::i32) = 0.0::fp64
stddev((10.0, 10.0, 10.0)::fp64) = 0.0::fp64

# negative: Examples with negative numbers
stddev((-10, -5, 0, 5, 10)::i32) = 7.0710678118654755::fp64
stddev((-2.5, -1.5, -0.5, 0.5, 1.5, 2.5)::fp64) = 1.707825127659933::fp64

# null_handling: Examples with null as input or output
stddev((1, Null, 3, Null, 5)::i32) = 1.632993161855452::fp64
stddev((Null, Null, Null)::i32) = Null::fp64
stddev(()::i32) = Null::fp64
stddev((10, Null, 20, 30)::i32) = 8.16496580927726::fp64

# single_value: Examples with single value
stddev((42)::i32) = 0.0::fp64
stddev((3.14)::fp64) = 0.0::fp64

# types: Examples demonstrating behavior of different data types
stddev((1::i8, 2::i8, 3::i8, 4::i8))::i8 = 1.118033988749895::fp64
stddev((100::i16, 200::i16, 300::i16))::i16 = 81.64965809277261::fp64
stddev((1.5::fp32, 2.5::fp32, 3.5::fp32))::fp32 = 0.8164965809277261::fp64