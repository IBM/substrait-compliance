### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_array.yaml'

# basic: Basic array concatenation
array_concat([1, 2]::list<i32>, [3, 4]::list<i32>) = [1, 2, 3, 4]::list<i32>
array_concat(['a', 'b']::list<str>, ['c', 'd']::list<str>) = ['a', 'b', 'c', 'd']::list<str>
array_concat([1.5, 2.5]::list<fp64>, [3.5, 4.5]::list<fp64>) = [1.5, 2.5, 3.5, 4.5]::list<fp64>

# empty: Concatenation with empty arrays
array_concat([1, 2, 3]::list<i32>, []::list<i32>) = [1, 2, 3]::list<i32>
array_concat([]::list<i32>, [1, 2, 3]::list<i32>) = [1, 2, 3]::list<i32>
array_concat([]::list<i32>, []::list<i32>) = []::list<i32>

# multiple: Concatenating multiple arrays
array_concat([1]::list<i32>, [2]::list<i32>, [3]::list<i32>) = [1, 2, 3]::list<i32>
array_concat(['a']::list<str>, ['b']::list<str>, ['c']::list<str>, ['d']::list<str>) = ['a', 'b', 'c', 'd']::list<str>

# null_handling: Arrays with null elements
array_concat([1, null]::list<i32>, [3, 4]::list<i32>) = [1, null, 3, 4]::list<i32>
array_concat([1, 2]::list<i32>, [null, 4]::list<i32>) = [1, 2, null, 4]::list<i32>
array_concat(null::list<i32>, [1, 2]::list<i32>) = null::list<i32>
array_concat([1, 2]::list<i32>, null::list<i32>) = null::list<i32>

# types: Different data types
array_concat([true, false]::list<bool>, [true]::list<bool>) = [true, false, true]::list<bool>
array_concat([100::i64, 200::i64]::list<i64>, [300::i64]::list<i64>) = [100, 200, 300]::list<i64>