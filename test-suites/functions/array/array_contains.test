### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_array.yaml'

# basic: Basic array contains check
array_contains([1, 2, 3, 4, 5]::list<i32>, 3::i32) = true::bool
array_contains([1, 2, 3, 4, 5]::list<i32>, 6::i32) = false::bool
array_contains(['a', 'b', 'c']::list<str>, 'b'::str) = true::bool
array_contains(['a', 'b', 'c']::list<str>, 'd'::str) = false::bool

# empty: Empty array
array_contains([]::list<i32>, 1::i32) = false::bool
array_contains([]::list<str>, 'a'::str) = false::bool

# null_handling: Arrays with null elements
array_contains([1, null, 3]::list<i32>, null::i32) = true::bool
array_contains([1, 2, 3]::list<i32>, null::i32) = false::bool
array_contains(null::list<i32>, 1::i32) = null::bool
array_contains([1, 2, 3]::list<i32>, null::i32) = false::bool

# types: Different data types
array_contains([1.5, 2.5, 3.5]::list<fp64>, 2.5::fp64) = true::bool
array_contains([true, false, true]::list<bool>, false::bool) = true::bool
array_contains([100::i64, 200::i64, 300::i64]::list<i64>, 200::i64) = true::bool

# edge_cases: First and last elements
array_contains([1, 2, 3, 4, 5]::list<i32>, 1::i32) = true::bool
array_contains([1, 2, 3, 4, 5]::list<i32>, 5::i32) = true::bool

# duplicates: Arrays with duplicate values
array_contains([1, 2, 2, 3, 3, 3]::list<i32>, 2::i32) = true::bool
array_contains([1, 2, 2, 3, 3, 3]::list<i32>, 4::i32) = false::bool