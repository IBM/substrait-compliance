### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_array.yaml'

# basic: Basic array position search (1-based indexing)
array_position([1, 2, 3, 4, 5]::list<i32>, 3::i32) = 3::i32
array_position([1, 2, 3, 4, 5]::list<i32>, 1::i32) = 1::i32
array_position([1, 2, 3, 4, 5]::list<i32>, 5::i32) = 5::i32
array_position(['a', 'b', 'c', 'd']::list<str>, 'c'::str) = 3::i32

# not_found: Element not in array
array_position([1, 2, 3, 4, 5]::list<i32>, 10::i32) = 0::i32
array_position(['a', 'b', 'c']::list<str>, 'z'::str) = 0::i32

# empty: Empty array
array_position([]::list<i32>, 1::i32) = 0::i32

# duplicates: First occurrence in arrays with duplicates
array_position([1, 2, 2, 3, 3, 3]::list<i32>, 2::i32) = 2::i32
array_position([1, 2, 2, 3, 3, 3]::list<i32>, 3::i32) = 4::i32
array_position(['a', 'b', 'a', 'c']::list<str>, 'a'::str) = 1::i32

# null_handling: Arrays with null elements
array_position([1, null, 3]::list<i32>, null::i32) = 2::i32
array_position([1, 2, 3]::list<i32>, null::i32) = 0::i32
array_position(null::list<i32>, 1::i32) = null::i32

# types: Different data types
array_position([1.5, 2.5, 3.5]::list<fp64>, 2.5::fp64) = 2::i32
array_position([true, false, true]::list<bool>, false::bool) = 2::i32
array_position([100::i64, 200::i64, 300::i64]::list<i64>, 300::i64) = 3::i32