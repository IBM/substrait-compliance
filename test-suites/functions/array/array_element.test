### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_array.yaml'

# basic: Basic array element access (0-based indexing)
array_element([1, 2, 3, 4, 5]::list<i32>, 0::i32) = 1::i32
array_element([1, 2, 3, 4, 5]::list<i32>, 2::i32) = 3::i32
array_element([1, 2, 3, 4, 5]::list<i32>, 4::i32) = 5::i32
array_element(['a', 'b', 'c']::list<str>, 0::i32) = 'a'::str
array_element(['a', 'b', 'c']::list<str>, 2::i32) = 'c'::str

# negative_index: Negative indexing (from end)
array_element([1, 2, 3, 4, 5]::list<i32>, -1::i32) = 5::i32
array_element([1, 2, 3, 4, 5]::list<i32>, -2::i32) = 4::i32
array_element([1, 2, 3, 4, 5]::list<i32>, -5::i32) = 1::i32
array_element(['a', 'b', 'c']::list<str>, -1::i32) = 'c'::str

# null_handling: Null elements and arrays
array_element([1, null, 3]::list<i32>, 1::i32) = null::i32
array_element(null::list<i32>, 0::i32) = null::i32
array_element([1, 2, 3]::list<i32>, null::i32) = null::i32

# out_of_bounds: Out of bounds access
array_element([1, 2, 3]::list<i32>, 5::i32) = null::i32
array_element([1, 2, 3]::list<i32>, -10::i32) = null::i32
array_element([]::list<i32>, 0::i32) = null::i32

# types: Different data types
array_element([1.5, 2.5, 3.5]::list<fp64>, 1::i32) = 2.5::fp64
array_element([true, false, true]::list<bool>, 0::i32) = true::bool
array_element([100::i64, 200::i64, 300::i64]::list<i64>, 2::i32) = 300::i64


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
array_element([1, 2, 3]::list<i32>, 2147483647::i32) = null::i32
array_element([1, 2, 3]::list<i32>, -2147483648::i32) = null::i32
array_element([127::i8, -128::i8, 0::i8]::list<i8>, 2::i32) = 0::i8

# null_handling_extended: Extended null handling scenarios
array_element([null, null, null]::list<i32>, 0::i32) = null::i32
array_element([null, null, null]::list<i32>, 1::i32) = null::i32
array_element([null]::list<i32>, 0::i32) = null::i32
array_element([null, 1, null, 2]::list<i32>, 1::i32) = 1::i32
array_element([null, 1, null, 2]::list<i32>, 2::i32) = null::i32
array_element([1, 2, 3, null]::list<i32>, 3::i32) = null::i32

# zero_handling: Zero and negative zero handling
array_element([[1, 2], [3, 4], [5, 6]]::list<list<i32>>, 0::i32) = [1, 2]::list<i32>
array_element([1]::list<i32>, 0::i32) = 1::i32
array_element(['single']::list<str>, 0::i32) = 'single'::str
array_element([100::i16, 200::i16, 300::i16]::list<i16>, 0::i32) = 100::i16
array_element([0.0::fp32, -0.0::fp32, 1.0::fp32]::list<fp32>, 0::i32) = 0.0::fp32
array_element(['']::list<str>, 0::i32) = ''::str

# empty_values: Empty strings and collections
array_element(['', 'a', '']::list<str>, 2::i32) = ''::str

# negative_values: Negative number handling
array_element([42]::list<i32>, -1::i32) = 42::i32

# type_coverage: Various data type coverage
array_element([[1, 2], [3, 4], [5, 6]]::list<list<i32>>, 2::i32) = [5, 6]::list<i32>
array_element([['a', 'b'], ['c', 'd']]::list<list<str>>, 1::i32) = ['c', 'd']::list<str>
array_element([1::i8, 2::i8, 3::i8]::list<i8>, 1::i32) = 2::i8
array_element([1.5::fp32, 2.5::fp32, 3.5::fp32]::list<fp32>, 1::i32) = 2.5::fp32
array_element([' ', '  ', '   ']::list<str>, 1::i32) = '  '::str

