### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic examples without any special cases
asin(0.0::fp32) = 0.0::fp32
asin(1.0::fp64) = 1.5707963267948966::fp64
asin(0.009::fp64) = 0.009000121504428887::fp64
asin(-0.009::fp64) = -0.009000121504428887::fp64
asin(null::fp64) = null::fp64


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# special_values: Special floating point values (NaN, Infinity)
asin(1.1::fp32) = nan::fp32
asin(1.1::fp64) = nan::fp64
asin(-1.1::fp32) = nan::fp32
asin(-1.1::fp64) = nan::fp64
asin(2.0::fp32) = nan::fp32
asin(2.0::fp64) = nan::fp64
asin(-2.0::fp64) = nan::fp64
asin(nan::fp32) = nan::fp32
asin(nan::fp64) = nan::fp64
asin(inf::fp32) = nan::fp32
asin(inf::fp64) = nan::fp64
asin(-inf::fp32) = nan::fp32
asin(-inf::fp64) = nan::fp64

# zero_handling: Zero and negative zero handling
asin(-1.0::fp32) = -1.5707963267948966::fp32
asin(-1.0::fp64) = -1.5707963267948966::fp64
asin(1.0::fp32) = 1.5707963267948966::fp32
asin(0.5::fp32) = 0.5235987755982989::fp32
asin(0.5::fp64) = 0.5235987755982989::fp64
asin(-0.5::fp32) = -0.5235987755982989::fp32
asin(-0.5::fp64) = -0.5235987755982989::fp64
asin(0.7071067811865476::fp64) = 0.7853981633974483::fp64
asin(0.0::fp32) = 0.0::fp32
asin(-0.009::fp32) = -0.009000121504428887::fp32
asin(0.866025403784439::fp32) = 1.0471975511965979::fp32

