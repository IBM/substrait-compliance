# basic: Basic examples without any special cases
shift_left(2::i32, 1::i32) = 4::i32
shift_left(511::i32, 8::i32) = 130816::i32
shift_left(301989888::i64, 3::i32) = 2415919104::i64
shift_left(301989888::i64, 8::i32) = 19791209299968::i64
shift_left(-3::i32, 1::i32) = -6::i32
shift_left(-3::i32, 2::i32) = -12::i32
shift_left(-3::i64, 1::i32) = -6::i64
shift_left(-3::i64, 2::i32) = -12::i64
shift_left(null::i64, 2::i32) = null::i64
shift_left(127::i64, null::i32) = null::i64


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
shift_left(1::i32, 31::i32) = -2147483648::i32
shift_left(1::i64, 63::i32) = -9223372036854775808::i64
shift_left(2147483647::i32, 1::i32) = -2::i32
shift_left(-2147483648::i32, 1::i32) = 0::i32
shift_left(9223372036854775807::i64, 1::i32) = -2::i64
shift_left(-9223372036854775808::i64, 1::i32) = 0::i64
shift_left(5::i32, 30::i32) = -2147483648::i32
shift_left(3::i32, 31::i32) = -2147483648::i32
shift_left(3::i64, 63::i32) = -9223372036854775808::i64

# null_handling_extended: Extended null handling scenarios
shift_left(null::i32, null::i32) = null::i32
shift_left(null::i64, null::i32) = null::i64

# zero_handling: Zero and negative zero handling
shift_left(0::i32, 5::i32) = 0::i32
shift_left(1::i32, 0::i32) = 1::i32
shift_left(0::i64, 10::i32) = 0::i64
shift_left(1::i64, 0::i32) = 1::i64
shift_left(1073741824::i32, 2::i32) = 0::i32
shift_left(536870912::i32, 3::i32) = 0::i32
shift_left(4611686018427387904::i64, 2::i32) = 0::i64
shift_left(2305843009213693952::i64, 3::i32) = 0::i64

# negative_values: Negative number handling
shift_left(5::i64, 62::i32) = -4611686018427387904::i64

