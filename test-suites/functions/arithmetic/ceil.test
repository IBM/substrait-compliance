### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic ceiling examples
ceil(3.14159::fp64) = 4::fp64
ceil(2.1::fp64) = 3::fp64
ceil(2.9::fp64) = 3::fp64
ceil(-2.1::fp64) = -2::fp64
ceil(-2.9::fp64) = -2::fp64
ceil(0.0::fp64) = 0::fp64
ceil(5.0::fp64) = 5::fp64

# null_handling: Examples with null as input
ceil(null::fp64) = null::fp64

# types: Examples with different numeric types
ceil(3.14159::fp32) = 4::fp32
ceil(2.1::fp32) = 3::fp32
ceil(-2.9::fp32) = -2::fp32

# edge_cases: Special floating point values
ceil(inf::fp64) = inf::fp64
ceil(-inf::fp64) = -inf::fp64
ceil(nan::fp64) = nan::fp64

# precision: Very small values
ceil(0.0001::fp64) = 1::fp64
ceil(-0.0001::fp64) = 0::fp64
ceil(1e-10::fp64) = 1::fp64


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# special_values: Special floating point values (NaN, Infinity)
ceil(inf::fp32) = inf::fp32
ceil(-inf::fp32) = -inf::fp32
ceil(nan::fp32) = nan::fp32

# zero_handling: Zero and negative zero handling
ceil(-0.0::fp64) = -0.0::fp64
ceil(-0.0::fp32) = -0.0::fp32
ceil(-2.2250738585072014e-308::fp64) = 0::fp64
ceil(-1.401298464324817e-45::fp32) = 0::fp32
ceil(0.9999999999999999::fp64) = 1::fp64
ceil(-0.9999999999999999::fp64) = 0::fp64
ceil(0.0001::fp32) = 1::fp32
ceil(-0.0001::fp32) = 0::fp32
ceil(-1e-10::fp32) = 0::fp32

# precision: Floating point precision and small values
ceil(2.2250738585072014e-308::fp64) = 1::fp64
ceil(1.401298464324817e-45::fp32) = 1::fp32
ceil(1e-10::fp32) = 1::fp32

# negative_values: Negative number handling
ceil(-1.7976931348623157e+308::fp64) = -1.7976931348623157e+308::fp64
ceil(-3.4028235e+38::fp32) = -3.4028235e+38::fp32

# type_coverage: Various data type coverage
ceil(1.7976931348623157e+308::fp64) = 1.7976931348623157e+308::fp64
ceil(3.4028235e+38::fp32) = 3.4028235e+38::fp32
ceil(1.9999999999999998::fp64) = 2::fp64
ceil(2.0000000000000004::fp64) = 3::fp64

