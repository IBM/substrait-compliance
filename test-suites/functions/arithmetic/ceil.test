### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic ceiling examples
ceil(3.14159::fp64) = 4::fp64
ceil(2.1::fp64) = 3::fp64
ceil(2.9::fp64) = 3::fp64
ceil(-2.1::fp64) = -2::fp64
ceil(-2.9::fp64) = -2::fp64
ceil(0.0::fp64) = 0::fp64
ceil(5.0::fp64) = 5::fp64

# null_handling: Examples with null as input
ceil(null::fp64) = null::fp64

# types: Examples with different numeric types
ceil(3.14159::fp32) = 4::fp32
ceil(2.1::fp32) = 3::fp32
ceil(-2.9::fp32) = -2::fp32

# edge_cases: Special floating point values
ceil(inf::fp64) = inf::fp64
ceil(-inf::fp64) = -inf::fp64
ceil(nan::fp64) = nan::fp64

# precision: Very small values
ceil(0.0001::fp64) = 1::fp64
ceil(-0.0001::fp64) = 0::fp64
ceil(1e-10::fp64) = 1::fp64