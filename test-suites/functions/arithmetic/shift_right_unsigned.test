### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic examples without any special cases
shift_right_unsigned(2::i32, 1::i32) = 1::i32
shift_right_unsigned(1024::i32, 8::i32) = 4::i32
shift_right_unsigned(301989888::i64, 3::i32) = 37748736::i64
shift_right_unsigned(301989888::i64, 16::i32) = 4608::i64
shift_right_unsigned(-3::i32, 1::i32) = 2147483646::i32
shift_right_unsigned(-3::i32, 2::i32) = 1073741823::i32
shift_right_unsigned(-3::i64, 1::i32) = 9223372036854775806::i64
shift_right_unsigned(-3::i64, 2::i32) = 4611686018427387903::i64
shift_right_unsigned(null::i64, 2::i32) = null::i64
shift_right_unsigned(127::i64, null::i32) = null::i64

# edge_cases: Boundary values and extreme inputs
shift_right_unsigned(2147483647::i32, 1::i32) = 1073741823::i32
shift_right_unsigned(-2147483648::i32, 1::i32) = 1073741824::i32
shift_right_unsigned(9223372036854775807::i64, 1::i32) = 4611686018427387903::i64
shift_right_unsigned(-9223372036854775808::i64, 1::i32) = 4611686018427387904::i64
shift_right_unsigned(-1::i32, 16::i32) = 65535::i32
shift_right_unsigned(-1::i64, 32::i32) = 4294967295::i64
shift_right_unsigned(2147483647::i32, 0::i32) = 2147483647::i32
shift_right_unsigned(-2147483648::i32, 0::i32) = -2147483648::i32
shift_right_unsigned(255::i32, 31::i32) = 0::i32
shift_right_unsigned(-2147483648::i32, 31::i32) = 1::i32
shift_right_unsigned(-9223372036854775808::i64, 63::i32) = 1::i64
shift_right_unsigned(-1::i32, 1::i32) = 2147483647::i32
shift_right_unsigned(-1::i64, 1::i32) = 9223372036854775807::i64

# null_handling_extended: Extended null handling scenarios
shift_right_unsigned(null::i32, null::i32) = null::i32
shift_right_unsigned(null::i64, null::i32) = null::i64

# zero_handling: Zero and negative zero handling
shift_right_unsigned(8::i32, 0::i32) = 8::i32
shift_right_unsigned(123456789::i64, 0::i32) = 123456789::i64
shift_right_unsigned(1::i32, 31::i32) = 0::i32
shift_right_unsigned(1::i64, 63::i32) = 0::i64

# negative_values: Negative number handling
shift_right_unsigned(-1::i32, 8::i32) = 16777215::i32
shift_right_unsigned(-1::i64, 8::i32) = 72057594037927935::i64

