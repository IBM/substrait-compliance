# edge_cases: Boundary values and extreme inputs
bitwise_or(-128::i8, 127::i8) = -1::i8
bitwise_or(-32768::i16, 32767::i16) = -1::i16
bitwise_or(-2147483648::i32, 2147483647::i32) = -1::i32
bitwise_or(-9223372036854775808::i64, 9223372036854775807::i64) = -1::i64
bitwise_or(85::i8, 170::i8) = 255::i8
bitwise_or(21845::i16, 43690::i16) = 65535::i16
bitwise_or(-128::i8, 0::i8) = -128::i8
bitwise_or(-128::i8, -128::i8) = -128::i8
bitwise_or(-32768::i16, 0::i16) = -32768::i16
bitwise_or(-2147483648::i32, 0::i32) = -2147483648::i32
bitwise_or(-9223372036854775808::i64, 0::i64) = -9223372036854775808::i64

# null_handling_extended: Extended null handling scenarios
bitwise_or(null::i8, null::i8) = null::i8
bitwise_or(null::i16, null::i16) = null::i16
bitwise_or(null::i32, null::i32) = null::i32

# zero_handling: Zero and negative zero handling
bitwise_or(0::i8, 0::i8) = 0::i8
bitwise_or(0::i16, 0::i16) = 0::i16
bitwise_or(0::i32, 0::i32) = 0::i32
bitwise_or(0::i64, 0::i64) = 0::i64

# negative_values: Negative number handling
bitwise_or(-1::i8, 50::i8) = -1::i8
bitwise_or(-1::i16, 12345::i16) = -1::i16
bitwise_or(-1::i32, 987654321::i32) = -1::i32
bitwise_or(-1::i64, 123456789012345::i64) = -1::i64

