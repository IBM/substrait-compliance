### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic truncation examples
trunc(3.14159::fp64) = 3::fp64
trunc(2.9::fp64) = 2::fp64
trunc(-2.1::fp64) = -2::fp64
trunc(-2.9::fp64) = -2::fp64
trunc(0.0::fp64) = 0::fp64
trunc(5.0::fp64) = 5::fp64

# null_handling: Examples with null as input
trunc(null::fp64) = null::fp64

# types: Examples with different numeric types
trunc(3.14159::fp32) = 3::fp32
trunc(2.9::fp32) = 2::fp32
trunc(-2.9::fp32) = -2::fp32

# edge_cases: Special floating point values
trunc(inf::fp64) = inf::fp64
trunc(-inf::fp64) = -inf::fp64
trunc(nan::fp64) = nan::fp64

# precision: Very small values
trunc(0.9999::fp64) = 0::fp64
trunc(-0.9999::fp64) = 0::fp64
trunc(1e-10::fp64) = 0::fp64
trunc(-1e-10::fp64) = 0::fp64

# zero_handling: Zero and negative zero handling
trunc(-0.0::fp64) = -0.0::fp64
trunc(-0.0::fp32) = -0.0::fp32
trunc(2.225073858507201e-308::fp64) = 0::fp64
trunc(-2.225073858507201e-308::fp64) = -0.0::fp64
trunc(1.4e-45::fp32) = 0::fp32
trunc(9007199254740993.0::fp64) = 9007199254740993::fp64
trunc(16777217.0::fp32) = 16777217::fp32

# negative_values: Negative number handling
trunc(-1.7976931348623157e308::fp64) = -1.7976931348623157e308::fp64
trunc(-3.4028235e38::fp32) = -3.4028235e38::fp32
trunc(-9007199254740992.5::fp64) = -9007199254740992::fp64
trunc(-1.0000000000000002::fp64) = -1::fp64
trunc(-2.9999999999999996::fp64) = -2::fp64
trunc(-999999999999999.9::fp64) = -999999999999999::fp64
trunc(-123456789.987654::fp64) = -123456789::fp64

# type_coverage: Various data type coverage
trunc(1.7976931348623157e308::fp64) = 1.7976931348623157e308::fp64
trunc(3.4028235e38::fp32) = 3.4028235e38::fp32
trunc(9007199254740992.5::fp64) = 9007199254740992::fp64
trunc(16777216.5::fp32) = 16777216::fp32
trunc(1.0000000000000002::fp64) = 1::fp64
trunc(2.9999999999999996::fp64) = 2::fp64
trunc(999999999999999.9::fp64) = 999999999999999::fp64
trunc(123456789.123456::fp64) = 123456789::fp64

