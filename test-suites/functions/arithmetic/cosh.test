### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic examples without any special cases
cosh(0.00::fp32) = 1.0::fp32
cosh(1.0::fp64) = 1.5430806348152437::fp64
cosh(7.0000009::fp64) = 548.3175286399451::fp64
cosh(-7.00000095::fp64) = 548.3175560557769::fp64
cosh(null::fp64) = null::fp64

# edge_cases: Boundary values and extreme inputs
cosh(0.5::fp64) = 1.1276259652063807::fp64

# special_values: Special floating point values (NaN, Infinity)
cosh(inf::fp64) = inf::fp64
cosh(-inf::fp64) = inf::fp64
cosh(nan::fp64) = nan::fp64
cosh(inf::fp32) = inf::fp32
cosh(-inf::fp32) = inf::fp32
cosh(nan::fp32) = nan::fp32
cosh(89.0::fp32) = inf::fp32
cosh(-89.0::fp32) = inf::fp32
cosh(710.0::fp64) = inf::fp64
cosh(-710.0::fp64) = inf::fp64

# zero_handling: Zero and negative zero handling
cosh(-1.0::fp64) = 1.5430806348152437::fp64
cosh(-0.1::fp64) = 1.0050041680558035::fp64
cosh(0.1::fp64) = 1.0050041680558035::fp64
cosh(-2.0::fp64) = 3.7621956910836314::fp64
cosh(2.0::fp64) = 3.7621956910836314::fp64
cosh(0.001::fp64) = 1.0000005000000417::fp64
cosh(-0.001::fp64) = 1.0000005000000417::fp64
cosh(0.01::fp32) = 1.00005::fp32
cosh(-0.01::fp32) = 1.00005::fp32
cosh(1.0::fp32) = 1.5430806::fp32
cosh(-1.0::fp32) = 1.5430806::fp32
cosh(2.0::fp32) = 3.7621956::fp32
cosh(5.0::fp32) = 74.20995::fp32
cosh(3.0::fp64) = 10.067661995777765::fp64
cosh(-3.0::fp64) = 10.067661995777765::fp64
cosh(10.0::fp64) = 11013.232920103324::fp64

