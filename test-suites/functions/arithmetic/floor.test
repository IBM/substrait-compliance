### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic floor examples
floor(3.14159::fp64) = 3::fp64
floor(2.1::fp64) = 2::fp64
floor(2.9::fp64) = 2::fp64
floor(-2.1::fp64) = -3::fp64
floor(-2.9::fp64) = -3::fp64
floor(0.0::fp64) = 0::fp64
floor(5.0::fp64) = 5::fp64

# null_handling: Examples with null as input
floor(null::fp64) = null::fp64

# types: Examples with different numeric types
floor(3.14159::fp32) = 3::fp32
floor(2.9::fp32) = 2::fp32
floor(-2.1::fp32) = -3::fp32

# edge_cases: Special floating point values
floor(inf::fp64) = inf::fp64
floor(-inf::fp64) = -inf::fp64
floor(nan::fp64) = nan::fp64

# precision: Very small values
floor(0.9999::fp64) = 0::fp64
floor(-0.0001::fp64) = -1::fp64
floor(1e-10::fp64) = 0::fp64


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# zero_handling: Zero and negative zero handling
floor(2.2250738585072014e-308::fp64) = 0::fp64
floor(-0.0::fp64) = -0.0::fp64
floor(-0.0::fp32) = -0.0::fp32
floor(1e15 + 0.5::fp64) = 1e15::fp64
floor(-1e15 - 0.5::fp64) = -1e15 - 1::fp64
floor(1e-308::fp64) = 0::fp64
floor(1e-45::fp32) = 0::fp32

# precision: Floating point precision and small values
floor(-1e-308::fp64) = -1::fp64
floor(-1e-45::fp32) = -1::fp32

# negative_values: Negative number handling
floor(-1.7976931348623157e308::fp64) = -1.7976931348623157e308::fp64
floor(-3.4028235e38::fp32) = -3.4028235e38::fp32
floor(-2.9999999999999996::fp64) = -3::fp64

# type_coverage: Various data type coverage
floor(1.7976931348623157e308::fp64) = 1.7976931348623157e308::fp64
floor(3.4028235e38::fp32) = 3.4028235e38::fp32
floor(9007199254740992.5::fp64) = 9007199254740992::fp64
floor(2.9999999999999996::fp64) = 2::fp64
floor(16777216.5::fp32) = 16777216::fp32

