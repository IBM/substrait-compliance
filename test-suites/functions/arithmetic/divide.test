### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic examples without any special cases
divide(25::i8, 5::i8) = 5::i8
divide(200::i16, -100::i16) = -2::i16
divide(60000::i32, 200::i32) = 300::i32
divide(4000000000::i64, -5000::i64) = -800000::i64

# division_by_zero: Examples demonstrating division by zero
divide(5::i8, 0::i8) [on_division_by_zero:NAN] = null::i8
divide(5::i8, 0::i8) [on_division_by_zero:ERROR] = <!ERROR>

# overflow: Examples demonstrating overflow behavior
divide(-9223372036854775808::i64, -1::i64) [overflow:ERROR] = <!ERROR>
divide(-128::i8, -1::i8) [overflow:SATURATE] = 127::i8

# floating_exception: Examples demonstrating exceptional floating point cases
divide(1.5e+208::fp64, 1.5e-200::fp64) = inf::fp64
divide(1.5e+200::fp64, -1.5e-208::fp64) = -inf::fp64

# overflow_behavior: Overflow and saturation behavior
divide(-32768::i16, -1::i16) [overflow:ERROR] = <!ERROR>
divide(-32768::i16, -1::i16) [overflow:SATURATE] = 32767::i16
divide(-2147483648::i32, -1::i32) [overflow:ERROR] = <!ERROR>
divide(-2147483648::i32, -1::i32) [overflow:SATURATE] = 2147483647::i32

# special_values: Special floating point values (NaN, Infinity)
divide(10::i16, 0::i16) [on_division_by_zero:NAN] = null::i16
divide(1000::i64, 0::i64) [on_division_by_zero:NAN] = null::i64

# null_handling_extended: Extended null handling scenarios
divide(null::i8, 5::i8) = null::i8
divide(10::i16, null::i16) = null::i16
divide(null::i32, null::i32) = null::i32
divide(null::i64, 100::i64) = null::i64
divide(null::fp32, 2.5::fp32) = null::fp32
divide(7.5::fp64, null::fp64) = null::fp64

# zero_handling: Zero and negative zero handling
divide(10.5::fp32, 2.0::fp32) = 5.25::fp32
divide(100.0::fp64, 4.0::fp64) = 25.0::fp64
divide(-15.5::fp32, 5.0::fp32) = -3.1::fp32
divide(100.0::fp64, 3.0::fp64) = 33.333333333333336::fp64
divide(1::i16, 3::i16) = 0::i16
divide(0::i8, 5::i8) = 0::i8
divide(0::i16, -10::i16) = 0::i16
divide(0::i32, 100::i32) = 0::i32
divide(0::i64, 999::i64) = 0::i64
divide(0.0::fp32, 2.5::fp32) = 0.0::fp32
divide(0.0::fp64, -7.3::fp64) = 0.0::fp64
divide(100::i32, 0::i32) [on_division_by_zero:ERROR] = <!ERROR>
divide(-50::i16, 0::i16) [on_division_by_zero:ERROR] = <!ERROR>

# negative_values: Negative number handling
divide(-7::i32, 2::i32) = -3::i32
divide(-10::i64, 3::i64) = -3::i64

# type_coverage: Various data type coverage
divide(7::i32, 2::i32) = 3::i32
divide(10::i8, 3::i8) = 3::i8

