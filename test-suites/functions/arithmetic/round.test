### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic rounding examples
round(3.14159::fp64) = 3::fp64
round(2.5::fp64) = 3::fp64
round(2.4::fp64) = 2::fp64
round(-2.5::fp64) = -3::fp64
round(-2.4::fp64) = -2::fp64
round(0.0::fp64) = 0::fp64

# precision: Rounding to specific decimal places
round(3.14159::fp64, 2::i32) = 3.14::fp64
round(3.14159::fp64, 3::i32) = 3.142::fp64
round(123.456::fp64, 1::i32) = 123.5::fp64
round(123.456::fp64, 0::i32) = 123::fp64
round(123.456::fp64, -1::i32) = 120::fp64
round(123.456::fp64, -2::i32) = 100::fp64

# null_handling: Examples with null as input
round(null::fp64) = null::fp64
round(3.14::fp64, null::i32) = null::fp64
round(null::fp64, 2::i32) = null::fp64

# types: Examples with different numeric types
round(3.14159::fp32) = 3::fp32
round(2.5::fp32) = 3::fp32
round(123.456::fp32, 1::i32) = 123.5::fp32

# edge_cases: Special floating point values
round(inf::fp64) = inf::fp64
round(-inf::fp64) = -inf::fp64
round(nan::fp64) = nan::fp64


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# special_values: Special floating point values (NaN, Infinity)
round(inf::fp64, 5::i32) = inf::fp64
round(-inf::fp64, 5::i32) = -inf::fp64
round(nan::fp64, 5::i32) = nan::fp64

# zero_handling: Zero and negative zero handling
round(0.5::fp64) = 1::fp64
round(-0.5::fp64) = -1::fp64
round(2.2250738585072014e-308::fp64) = 0::fp64
round(4.9e-324::fp64) = 0::fp64
round(-4.9e-324::fp64) = -0::fp64
round(-0.0::fp64) = -0::fp64
round(-0.0::fp64, 2::i32) = -0::fp64
round(123.456::fp64, -10::i32) = 0::fp64
round(1.23456e100::fp64, -101::i32) = 0::fp64
round(2.225e-308::fp64) = 0::fp64
round(1e-320::fp64) = 0::fp64
round(-1e-320::fp64) = -0::fp64
round(1.1754944e-38::fp32) = 0::fp32
round(1.4e-45::fp32) = 0::fp32
round(0.5::fp32) = 1::fp32
round(-0.5::fp32) = -1::fp32
round(123.456::fp64, -308::i32) = 0::fp64
round(0.0::fp64, -5::i32) = 0::fp64
round(-0.0::fp64, -5::i32) = -0::fp64

# negative_values: Negative number handling
round(-1.5::fp64) = -2::fp64
round(-3.5::fp64) = -4::fp64
round(-1.7976931348623157e308::fp64) = -1.7976931348623157e308::fp64
round(-3.4028235e38::fp32) = -3.4028235e38::fp32
round(9.999e307::fp64, -307::i32) = 1e308::fp64

# type_coverage: Various data type coverage
round(1.5::fp64) = 2::fp64
round(3.5::fp64) = 4::fp64
round(1.7976931348623157e308::fp64) = 1.7976931348623157e308::fp64
round(123.456::fp64, 10::i32) = 123.456::fp64
round(123.456::fp64, 15::i32) = 123.456::fp64
round(3.4028235e38::fp32) = 3.4028235e38::fp32
round(123.456::fp64, 308::i32) = 123.456::fp64

# mixed_magnitude: Mixed magnitude values
round(1.23456e100::fp64, -100::i32) = 1e100::fp64

