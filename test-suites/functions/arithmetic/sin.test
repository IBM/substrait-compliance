### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic examples without any special cases
sin(0.0::fp32) = 0.0::fp32
sin(1.0::fp64) = 0.8414709848078965::fp64
sin(7.0000009::fp64) = 0.6569872772305518::fp64
sin(-7.0000009::fp64) = -0.6569872772305518::fp64
sin(null::fp64) = null::fp64


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
sin(0.5::fp32) = 0.479425538604203::fp32
sin(-0.5::fp32) = -0.479425538604203::fp32

# special_values: Special floating point values (NaN, Infinity)
sin(nan::fp32) = nan::fp32
sin(nan::fp64) = nan::fp64
sin(inf::fp32) = nan::fp32
sin(inf::fp64) = nan::fp64
sin(-inf::fp32) = nan::fp32
sin(-inf::fp64) = nan::fp64

# zero_handling: Zero and negative zero handling
sin(-0.0::fp32) = -0.0::fp32
sin(-0.0::fp64) = -0.0::fp64
sin(1.5707963267948966::fp64) = 1.0::fp64  # π/2
sin(3.141592653589793::fp64) = 0.0::fp64  # π
sin(4.71238898038469::fp64) = -1.0::fp64  # 3π/2
sin(6.283185307179586::fp64) = 0.0::fp64  # 2π
sin(1.5707963::fp32) = 1.0::fp32  # π/2 in fp32
sin(3.1415927::fp32) = 0.0::fp32  # π in fp32
sin(2.5::fp32) = 0.5984721441039565::fp32
sin(-2.5::fp32) = -0.5984721441039565::fp32
sin(1000.0::fp64) = -0.8268795405320025::fp64
sin(-1000.0::fp64) = 0.8268795405320025::fp64
sin(1e10::fp64) = -0.3048106211022167::fp64
sin(1e15::fp64) = -0.9301436974926853::fp64
sin(0.7853981633974483::fp64) = 0.7071067811865475::fp64  # π/4
sin(-0.7853981633974483::fp64) = -0.7071067811865475::fp64  # -π/4
sin(2.0::fp32) = 0.9092974268256817::fp32
sin(-2.0::fp32) = -0.9092974268256817::fp32

