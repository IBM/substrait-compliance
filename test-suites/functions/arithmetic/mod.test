### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic modulo examples
mod(10::i32, 3::i32) = 1::i32
mod(17::i32, 5::i32) = 2::i32
mod(20::i32, 4::i32) = 0::i32
mod(7::i64, 3::i64) = 1::i64
mod(100::i64, 7::i64) = 2::i64

# negative: Modulo with negative numbers
mod(-10::i32, 3::i32) = -1::i32
mod(10::i32, -3::i32) = 1::i32
mod(-10::i32, -3::i32) = -1::i32
mod(-17::i64, 5::i64) = -2::i64

# floating_point: Floating point modulo
mod(10.5::fp64, 3.0::fp64) = 1.5::fp64
mod(17.7::fp64, 5.0::fp64) = 2.7::fp64
mod(20.0::fp64, 4.0::fp64) = 0.0::fp64

# null_handling: Examples with null as input
mod(null::i32, 3::i32) = null::i32
mod(10::i32, null::i32) = null::i32
mod(null::fp64, 3.0::fp64) = null::fp64

# types: Examples with different numeric types
mod(10::i8, 3::i8) = 1::i8
mod(1000::i16, 7::i16) = 6::i16
mod(10.5::fp32, 3.0::fp32) = 1.5::fp32

# edge_cases: Division by zero and special cases
mod(10::i32, 0::i32) [division_by_zero:ERROR] = <!ERROR>
mod(10.0::fp64, 0.0::fp64) = nan::fp64
mod(inf::fp64, 3.0::fp64) = nan::fp64
mod(10.0::fp64, inf::fp64) = 10.0::fp64
mod(nan::fp64, 3.0::fp64) = nan::fp64

# edge_cases: Boundary values and extreme inputs
mod(-2147483648::i32, -1::i32) = 0::i32
mod(-9223372036854775808::i64, -1::i64) = 0::i64
mod(2147483647::i32, 1::i32) = 0::i32
mod(9223372036854775807::i64, 1::i64) = 0::i64
mod(-128::i8, -1::i8) = 0::i8
mod(-32768::i16, -1::i16) = 0::i16
mod(2147483647::i32, 2::i32) = 1::i32
mod(-2147483648::i32, 2::i32) = 0::i32
mod(9223372036854775807::i64, 3::i64) = 1::i64
mod(-9223372036854775808::i64, 3::i64) = -2::i64
mod(127::i8, 10::i8) = 7::i8
mod(-128::i8, 10::i8) = -8::i8

# special_values: Special floating point values (NaN, Infinity)
mod(-inf::fp64, 3.0::fp64) = nan::fp64
mod(0.0::fp64, 0.0::fp64) = nan::fp64
mod(3.0::fp64, nan::fp64) = nan::fp64
mod(10.0::fp32, nan::fp32) = nan::fp32
mod(-inf::fp32, 2.0::fp32) = nan::fp32

# zero_handling: Zero and negative zero handling
mod(0::i32, 3::i32) = 0::i32
mod(0::i64, 5::i64) = 0::i64
mod(0::i8, 7::i8) = 0::i8
mod(0::i16, 11::i16) = 0::i16
mod(0.0::fp32, 3.0::fp32) = 0.0::fp32
mod(0.0::fp64, 5.0::fp64) = 0.0::fp64
mod(-10.5::fp64, 3.0::fp64) = -1.5::fp64
mod(10.5::fp64, -3.0::fp64) = 1.5::fp64
mod(-10.5::fp64, -3.0::fp64) = -1.5::fp64
mod(-7.5::fp32, 2.5::fp32) = -0.0::fp32
mod(7.5::fp32, -2.5::fp32) = 0.0::fp32
mod(-0.0::fp64, 5.0::fp64) = -0.0::fp64

# type_coverage: Various data type coverage
mod(999999999::i32, 999999998::i32) = 1::i32

# mixed_magnitude: Mixed magnitude values
mod(1000000::i32, 7::i32) = 6::i32
mod(1000000000::i64, 13::i64) = 4::i64
mod(1000000000000::i64, 999999999999::i64) = 1::i64

