### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_arithmetic.yaml'

# basic: Basic modulo examples
mod(10::i32, 3::i32) = 1::i32
mod(17::i32, 5::i32) = 2::i32
mod(20::i32, 4::i32) = 0::i32
mod(7::i64, 3::i64) = 1::i64
mod(100::i64, 7::i64) = 2::i64

# negative: Modulo with negative numbers
mod(-10::i32, 3::i32) = -1::i32
mod(10::i32, -3::i32) = 1::i32
mod(-10::i32, -3::i32) = -1::i32
mod(-17::i64, 5::i64) = -2::i64

# floating_point: Floating point modulo
mod(10.5::fp64, 3.0::fp64) = 1.5::fp64
mod(17.7::fp64, 5.0::fp64) = 2.7::fp64
mod(20.0::fp64, 4.0::fp64) = 0.0::fp64

# null_handling: Examples with null as input
mod(null::i32, 3::i32) = null::i32
mod(10::i32, null::i32) = null::i32
mod(null::fp64, 3.0::fp64) = null::fp64

# types: Examples with different numeric types
mod(10::i8, 3::i8) = 1::i8
mod(1000::i16, 7::i16) = 6::i16
mod(10.5::fp32, 3.0::fp32) = 1.5::fp32

# edge_cases: Division by zero and special cases
mod(10::i32, 0::i32) [division_by_zero:ERROR] = <!ERROR>
mod(10.0::fp64, 0.0::fp64) = nan::fp64
mod(inf::fp64, 3.0::fp64) = nan::fp64
mod(10.0::fp64, inf::fp64) = 10.0::fp64
mod(nan::fp64, 3.0::fp64) = nan::fp64