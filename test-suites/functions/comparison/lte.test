### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_comparison.yaml'

# basic: Basic examples without any special cases
lte(1::i8, 2::i8) = true::bool
lte(2::i8, 2::i8) = true::bool
lte(200::i16, 199::i16) = false::bool
lte(2000000000::i32, 1000000000::i32) = false::bool
lte(-922337203685775808::i64, -922337203685775807::i64) = true::bool
lte(7.00::fp32, 2.50::fp32) = false::bool
lte(7.25::fp32, 7.25::fp32) = true::bool
lte(7.25::dec<38, 2>, 7.25::dec<38, 2>) = true::bool
lte(2.59::dec<38, 2>, 2.50::dec<38, 2>) = false::bool
lte(1.5e+308::fp64, inf::fp64) = true::bool
lte(inf::fp64, inf::fp64) = true::bool
lte(-1.5e+308::fp64, -inf::fp64) = false::bool

# null_input: Examples with null as input
lte(null::dec<38, 2>, 2.50::dec<38, 2>) = null::bool
lte(null::dec<38, 2>, null::dec<38, 2>) = null::bool
lte(null::i16, 1::i16) = null::bool
lte(2::i16, null::i16) = null::bool
lte(null::i16, null::i16) = null::bool


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
lte(-128::i8, -127::i8) = true::bool
lte(-128::i8, -128::i8) = true::bool
lte(-128::i8, 0::i8) = true::bool
lte(-32768::i16, -32767::i16) = true::bool
lte(-32768::i16, -32768::i16) = true::bool
lte(-2147483648::i32, -2147483647::i32) = true::bool
lte(-2147483648::i32, -2147483648::i32) = true::bool
lte(-9223372036854775808::i64, -9223372036854775807::i64) = true::bool
lte(-9223372036854775808::i64, -9223372036854775808::i64) = true::bool
lte(127::i8, 127::i8) = true::bool
lte(127::i8, 126::i8) = false::bool
lte(32767::i16, 32767::i16) = true::bool
lte(32767::i16, 32766::i16) = false::bool
lte(2147483647::i32, 2147483647::i32) = true::bool
lte(2147483647::i32, 2147483646::i32) = false::bool
lte(9223372036854775807::i64, 9223372036854775807::i64) = true::bool
lte(9223372036854775807::i64, 9223372036854775806::i64) = false::bool

# special_values: Special floating point values (NaN, Infinity)
lte(nan::fp32, 5.0::fp32) = false::bool
lte(5.0::fp32, nan::fp32) = false::bool
lte(nan::fp32, nan::fp32) = false::bool
lte(nan::fp64, 100.0::fp64) = false::bool
lte(100.0::fp64, nan::fp64) = false::bool
lte(nan::fp64, nan::fp64) = false::bool
lte(-inf::fp64, -inf::fp64) = true::bool
lte(-inf::fp64, 0.0::fp64) = true::bool
lte(-inf::fp64, 1.5e+308::fp64) = true::bool
lte(-inf::fp32, -inf::fp32) = true::bool
lte(-inf::fp32, 0.0::fp32) = true::bool

# zero_handling: Zero and negative zero handling
lte(0.0::fp32, -0.0::fp32) = true::bool
lte(-0.0::fp32, 0.0::fp32) = true::bool
lte(0.0::fp64, -0.0::fp64) = true::bool
lte(-0.0::fp64, 0.0::fp64) = true::bool

# negative_values: Negative number handling
lte(-50::i8, -25::i8) = true::bool
lte(-25::i8, -50::i8) = false::bool
lte(-1000::i16, -500::i16) = true::bool
lte(-500::i16, -1000::i16) = false::bool
lte(-5.75::fp32, -2.25::fp32) = true::bool
lte(-2.25::fp32, -5.75::fp32) = false::bool
lte(-100.50::fp64, -50.25::fp64) = true::bool
lte(-9.99::dec<38, 2>, -5.50::dec<38, 2>) = true::bool

# mixed_magnitude: Mixed magnitude values
lte(-1000000::i32, -500000::i32) = true::bool

