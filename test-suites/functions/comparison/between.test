# zero_handling: Zero and negative zero handling
between(0::i8, 0::i8, 0::i8) = true::bool
between(3.5::fp32, 1.0::fp32, 5.0::fp32) = true::bool
between(1.5::fp32, 2.0::fp32, 3.0::fp32) = false::bool
between(0.0::fp32, -1.0::fp32, 1.0::fp32) = true::bool
between(-0.0::fp32, -1.0::fp32, 1.0::fp32) = true::bool
between(3.5::fp64, 1.0::fp64, 5.0::fp64) = true::bool
between(1.5::fp64, 2.0::fp64, 3.0::fp64) = false::bool
between(0::i8, -10::i8, 10::i8) = true::bool
between(0::i16, -1000::i16, 1000::i16) = true::bool
between(0::i32, -100000::i32, 100000::i32) = true::bool
between(0::i64, -1000000000::i64, 1000000000::i64) = true::bool
between(0.0::fp32, -10.0::fp32, 10.0::fp32) = true::bool
between(0.0::fp64, -10.0::fp64, 10.0::fp64) = true::bool
between(0::i8, 1::i8, 10::i8) = false::bool
