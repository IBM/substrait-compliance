# basic: Basic examples without any special cases
between(5::i8, 0::i8, 127::i8) = true::bool
between(20000::i16, 1::i16, 30000::i16) = true::bool
between(1030000000::i32, 1000000000::i32, 2000000000::i32) = true::bool
between(10300000000900::i64, 1000000000::i64, 9223372036854775807::i64) = true::bool
between(2::i8, 1::i8, -120::i8) = false::bool
between(2::i8, 2::i8, 3::i8) = true::bool
between(2::i8, 1::i8, 2::i8) = true::bool
between(-10000::i16, -20000::i16, -30000::i16) = false::bool
between(-100000000::i32, -1000000000::i32, -2000000000::i32) = false::bool
between(92233720368547758::i64, 1::i64, -9223372036854775807::i64) = false::bool
between(14.01::fp32, 20.90::fp32, 88.00::fp32) = false::bool
between(14.011::fp64, 0.00::fp64, inf::fp64) = true::bool
between(inf::fp64, 0.00::fp64, 100.09::fp64) = false::bool
between(-100.0011::fp64, -inf::fp64, 0.00::fp64) = true::bool

# null_input: Examples with null as input
between(null::i8, 1::i8, 10::i8) = null::bool
between(1::i64, null::i64, 10::i64) = null::bool
between(1::i64, 1::i64, null::i64) = null::bool

# edge_cases: Boundary values and extreme inputs
between(127::i8, -128::i8, 127::i8) = true::bool
between(-128::i8, -128::i8, 127::i8) = true::bool
between(32767::i16, -32768::i16, 32767::i16) = true::bool
between(-32768::i16, -32768::i16, 32767::i16) = true::bool
between(2147483647::i32, -2147483648::i32, 2147483647::i32) = true::bool
between(-2147483648::i32, -2147483648::i32, 2147483647::i32) = true::bool
between(9223372036854775807::i64, -9223372036854775808::i64, 9223372036854775807::i64) = true::bool
between(-9223372036854775808::i64, -9223372036854775808::i64, 9223372036854775807::i64) = true::bool

# special_values: Special floating point values (NaN, Infinity)
between(nan::fp32, 1.0::fp32, 5.0::fp32) = false::bool
between(3.0::fp32, nan::fp32, 5.0::fp32) = false::bool
between(3.0::fp32, 1.0::fp32, nan::fp32) = false::bool
between(inf::fp32, 1.0::fp32, 100.0::fp32) = false::bool
between(-inf::fp32, -100.0::fp32, 100.0::fp32) = true::bool
between(50.0::fp32, -inf::fp32, inf::fp32) = true::bool
between(nan::fp64, 1.0::fp64, 5.0::fp64) = false::bool
between(3.0::fp64, nan::fp64, 5.0::fp64) = false::bool
between(3.0::fp64, 1.0::fp64, nan::fp64) = false::bool
between(-inf::fp64, -100.0::fp64, 100.0::fp64) = true::bool
between(50.0::fp64, -inf::fp64, inf::fp64) = true::bool

# null_handling_extended: Extended null handling scenarios
between(null::i8, null::i8, 10::i8) = null::bool
between(null::i8, 1::i8, null::i8) = null::bool
