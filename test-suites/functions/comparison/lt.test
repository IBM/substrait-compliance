### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_comparison.yaml'

# basic: Basic examples without any special cases
lt(1::i8, 2::i8) = true::bool
lt(200::i16, 100::i16) = false::bool
lt(1000::i16, 1000::i16) = false::bool
lt(2000000000::i32, 1000000000::i32) = false::bool
lt(-922337203685775808::i64, -922337203685775807::i64) = true::bool
lt(7.25::fp32, 2.50::fp32) = false::bool
lt(7.25::dec<38, 2>, 7.25::dec<38, 2>) = false::bool
lt(2.49::dec<38, 2>, 2.50::dec<38, 2>) = true::bool
lt(1.5e+308::fp64, inf::fp64) = true::bool
lt(-1.5e+308::fp64, -inf::fp64) = false::bool

# null_input: Examples with null as input
lt(null::dec<38, 2>, 2.50::dec<38, 2>) = null::bool
lt(null::dec<38, 2>, null::dec<38, 2>) = null::bool
lt(null::i16, 1::i16) = null::bool
lt(2::i16, null::i16) = null::bool
lt(null::i16, null::i16) = null::bool

# edge_cases: Boundary values and extreme inputs
lt(-128::i8, 127::i8) = true::bool
lt(127::i8, -128::i8) = false::bool
lt(-32768::i16, 32767::i16) = true::bool
lt(32767::i16, -32768::i16) = false::bool
lt(-2147483648::i32, 2147483647::i32) = true::bool
lt(2147483647::i32, -2147483648::i32) = false::bool
lt(-9223372036854775808::i64, 9223372036854775807::i64) = true::bool
lt(9223372036854775807::i64, -9223372036854775808::i64) = false::bool
lt(-9223372036854775807::i64, -9223372036854775808::i64) = false::bool

# special_values: Special floating point values (NaN, Infinity)
lt(nan::fp32, 1.0::fp32) = false::bool
lt(1.0::fp32, nan::fp32) = false::bool
lt(nan::fp32, nan::fp32) = false::bool
lt(nan::fp32, 0.0::fp32) = false::bool
lt(-1.0::fp32, nan::fp32) = false::bool
lt(nan::fp64, 1.0::fp64) = false::bool
lt(1.0::fp64, nan::fp64) = false::bool
lt(nan::fp64, nan::fp64) = false::bool
lt(nan::fp64, inf::fp64) = false::bool
lt(-inf::fp64, nan::fp64) = false::bool
lt(inf::fp32, inf::fp32) = false::bool
lt(-inf::fp32, -inf::fp32) = false::bool
lt(-inf::fp32, inf::fp32) = true::bool
lt(inf::fp64, inf::fp64) = false::bool
lt(-inf::fp64, -inf::fp64) = false::bool
lt(-inf::fp64, inf::fp64) = true::bool

# zero_handling: Zero and negative zero handling
lt(0::i8, 0::i8) = false::bool
lt(0::i16, 0::i16) = false::bool
lt(0::i32, 0::i32) = false::bool
lt(0::i64, 0::i64) = false::bool
lt(0.0::fp32, 0.0::fp32) = false::bool
lt(-0.0::fp32, 0.0::fp32) = false::bool
lt(0.0::fp64, -0.0::fp64) = false::bool
lt(-1::i8, 0::i8) = true::bool
lt(-1::i16, 0::i16) = true::bool
lt(-1::i32, 0::i32) = true::bool
lt(-1::i64, 0::i64) = true::bool
lt(0::i8, -1::i8) = false::bool
lt(0.00::dec<38, 2>, 0.00::dec<38, 2>) = false::bool
lt(-1.00::dec<38, 2>, 0.00::dec<38, 2>) = true::bool
lt(99999999999999999999999999999999999999::dec<38, 0>, 99999999999999999999999999999999999998::dec<38, 0>) = false::bool

# negative_values: Negative number handling
lt(-100::i8, -50::i8) = true::bool
lt(-50::i8, -100::i8) = false::bool
lt(-1000::i16, -500::i16) = true::bool
lt(-7.25::fp32, -2.50::fp32) = true::bool
lt(-2.50::fp64, -7.25::fp64) = false::bool

# mixed_magnitude: Mixed magnitude values
lt(-2000000000::i32, -1000000000::i32) = true::bool

