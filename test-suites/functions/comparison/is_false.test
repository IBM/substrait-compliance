### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_comparison.yaml'

# basic: Basic examples without any special cases
is_false(true::bool) = false::bool
is_false(false::bool) = true::bool
is_false(null::bool) = false::bool

# null_handling_extended: Extended null handling scenarios
is_false(null::bool) = false::bool
is_false(is_false(null::bool)) = true::bool

# additional_coverage: Additional test coverage
is_false(1 > 2) = true::bool
is_false(5 < 10) = false::bool
is_false(10 == 10) = false::bool
is_false(3 != 3) = true::bool
is_false(is_false(true::bool)) = true::bool
is_false(is_false(false::bool)) = false::bool
is_false(true AND false) = false::bool
is_false(false OR false) = true::bool
is_false(true OR false) = false::bool
is_false(false AND false) = true::bool

