# null_handling_extended: Extended null handling scenarios
is_true(null::bool?) = false::bool
is_true(is_true(null::bool)) = false::bool
is_true(null::bool) = false::bool
is_true(null::bool?) = false::bool

# additional_coverage: Additional test coverage
is_true(true::bool?) = true::bool
is_true(false::bool?) = false::bool
