### SUBSTRAIT_WINDOW_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_window.yaml'

# basic: Basic examples without any special cases
lag(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30), (4, 40)) = (Null, 10, 20, 30)::i32
lag(value::i32, 2) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30), (4, 40)) = (Null, Null, 10, 20)::i32

# default_value: Examples with default value
lag(value::i32, 1, 0) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (0, 10, 20)::i32
lag(value::i32, 2, -1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (-1, -1, 10)::i32

# partition: Examples with partitioning
lag(value::i32, 1) OVER (PARTITION BY category::str ORDER BY id::i32) WITH (('A', 1, 10), ('A', 2, 20), ('B', 3, 30), ('B', 4, 40)) = (Null, 10, Null, 30)::i32
lag(salary::i32, 1, 0) OVER (PARTITION BY dept::str ORDER BY id::i32) WITH (('Sales', 1, 5000), ('Sales', 2, 6000), ('IT', 3, 7000)) = (0, 5000, 0)::i32

# offset_zero: Examples with offset 0 (returns same value)
lag(value::i32, 0) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (10, 20, 30)::i32

# null_values: Examples with null values in data
lag(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, Null), (3, 30)) = (Null, 10, Null)::i32
lag(value::i32, 1, 0) OVER (ORDER BY id::i32) WITH ((1, Null), (2, 20), (3, Null)) = (0, Null, 20)::i32

# string_type: Examples with string data type
lag(name::str, 1) OVER (ORDER BY id::i32) WITH ((1, 'Alice'), (2, 'Bob'), (3, 'Charlie')) = (Null, 'Alice', 'Bob')::str
lag(name::str, 1, 'Unknown') OVER (ORDER BY id::i32) WITH ((1, 'Alice'), (2, 'Bob')) = ('Unknown', 'Alice')::str

# floating_point: Examples with floating point values
lag(value::fp64, 1) OVER (ORDER BY id::i32) WITH ((1, 1.5), (2, 2.5), (3, 3.5)) = (Null, 1.5, 2.5)::fp64
lag(value::fp64, 1, 0.0) OVER (ORDER BY id::i32) WITH ((1, 1.5), (2, 2.5)) = (0.0, 1.5)::fp64

# large_offset: Examples with large offset
lag(value::i32, 5) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (Null, Null, Null)::i32
lag(value::i32, 10, -1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20)) = (-1, -1)::i32


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
lag(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, 2147483647), (2, 2147483646)) = (Null, 2147483647)::i32
lag(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, -2147483648), (2, -2147483647)) = (Null, -2147483648)::i32
lag(value::i32, 1, 0) OVER (ORDER BY id::i32) WITH ((1, 2147483647), (2, -2147483648)) = (0, 2147483647)::i32

# special_values: Special floating point values (NaN, Infinity)
lag(value::fp64, 1) OVER (ORDER BY id::i32) WITH ((1, NaN), (2, 2.5), (3, 3.5)) = (Null, NaN, 2.5)::fp64
lag(value::fp64, 1) OVER (ORDER BY id::i32) WITH ((1, Infinity), (2, -Infinity), (3, 0.0)) = (Null, Infinity, -Infinity)::fp64
lag(value::fp64, 1, 0.0) OVER (ORDER BY id::i32) WITH ((1, NaN), (2, Infinity)) = (0.0, NaN)::fp64

# null_handling_extended: Extended null handling scenarios
lag(value::i32, 1) OVER (ORDER BY id::i32 DESC) WITH ((3, 30), (2, 20), (1, 10)) = (Null, 30, 20)::i32
lag(value::i32, 2) OVER (ORDER BY id::i32 DESC) WITH ((4, 40), (3, 30), (2, 20), (1, 10)) = (Null, Null, 40, 30)::i32
lag(value::i32, 1) OVER (ORDER BY id::i32) WITH ((1, 10)) = (Null)::i32
lag(value::i32, 3) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (Null, Null, Null)::i32
lag(value::i32, 4) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (Null, Null, Null)::i32
lag(value::i32, 1) OVER (ORDER BY category::str, id::i32) WITH (('A', 2, 20), ('A', 1, 10), ('B', 1, 30)) = (Null, 10, 20)::i32
lag(value::i32, 1) OVER (PARTITION BY dept::str ORDER BY id::i32, value::i32) WITH (('Sales', 1, 100), ('Sales', 1, 200), ('Sales', 2, 150)) = (Null, 100, 200)::i32
lag(value::i32, 1, -1) OVER (PARTITION BY category::str ORDER BY id::i32) WITH (('A', 1, Null), ('A', 2, 20), ('B', 3, Null), ('B', 4, 40)) = (-1, Null, -1, Null)::i32

# zero_handling: Zero and negative zero handling
lag(value::i32, 1, 0) OVER (ORDER BY id::i32 DESC) WITH ((3, 30), (2, 20), (1, 10)) = (0, 30, 20)::i32
lag(value::i32, 1, 0) OVER (ORDER BY id::i32) WITH () = ()::i32
lag(value::i32, 2, 0) OVER (PARTITION BY category::str ORDER BY id::i32) WITH (('A', 1, 10), ('A', 2, 20), ('A', 3, 30), ('B', 4, 40)) = (0, 0, 10, 0)::i32

# single_value: Single value inputs
lag(value::i32, 1, 99) OVER (ORDER BY id::i32) WITH ((1, 10)) = (99)::i32
lag(value::str, 1, 'default') OVER (ORDER BY id::i32) WITH ((1, 'only')) = ('default')::str

# empty_values: Empty strings and collections
lag(value::i32, 1) OVER (ORDER BY id::i32) WITH () = ()::i32

# negative_values: Negative number handling
lag(value::i32, -1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = error::i32
lag(value::i32, 3, -1) OVER (ORDER BY id::i32) WITH ((1, 10), (2, 20), (3, 30)) = (-1, -1, -1)::i32

