### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_set.yaml'

# basic: Basic set intersection
intersect([1, 2, 3, 4]::list<i32>, [3, 4, 5, 6]::list<i32>) = [3, 4]::list<i32>
intersect(['a', 'b', 'c']::list<str>, ['b', 'c', 'd']::list<str>) = ['b', 'c']::list<str>
intersect([1, 2, 3]::list<i32>, [4, 5, 6]::list<i32>) = []::list<i32>

# empty: Intersection with empty sets
intersect([1, 2, 3]::list<i32>, []::list<i32>) = []::list<i32>
intersect([]::list<i32>, [1, 2, 3]::list<i32>) = []::list<i32>
intersect([]::list<i32>, []::list<i32>) = []::list<i32>

# duplicates: Intersection with duplicates
intersect([1, 1, 2, 2, 3]::list<i32>, [2, 2, 3, 3, 4]::list<i32>) = [2, 3]::list<i32>
intersect(['a', 'a', 'b', 'b']::list<str>, ['b', 'b', 'c']::list<str>) = ['b']::list<str>

# null_handling: Intersection with null elements
intersect([1, null, 3]::list<i32>, [null, 3, 4]::list<i32>) = [null, 3]::list<i32>
intersect(null::list<i32>, [1, 2, 3]::list<i32>) = null::list<i32>
intersect([1, 2, 3]::list<i32>, null::list<i32>) = null::list<i32>

# types: Different data types
intersect([1.5, 2.5, 3.5]::list<fp64>, [2.5, 3.5, 4.5]::list<fp64>) = [2.5, 3.5]::list<fp64>
intersect([true, false]::list<bool>, [false]::list<bool>) = [false]::list<bool>

# identical: Intersection of identical sets
intersect([1, 2, 3]::list<i32>, [1, 2, 3]::list<i32>) = [1, 2, 3]::list<i32>
intersect(['a', 'b']::list<str>, ['a', 'b']::list<str>) = ['a', 'b']::list<str>


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
intersect([9223372036854775807, -9223372036854775808]::list<i64>, [9223372036854775807]::list<i64>) = [9223372036854775807]::list<i64>
intersect([-2147483648, 0, 2147483647]::list<i32>, [-2147483648, 2147483647]::list<i32>) = [-2147483648, 2147483647]::list<i32>

# special_values: Special floating point values (NaN, Infinity)
intersect([inf, -inf, 1.0]::list<fp64>, [inf, 2.0]::list<fp64>) = [inf]::list<fp64>
intersect([-inf, 0.0, inf]::list<fp64>, [-inf, inf]::list<fp64>) = [-inf, inf]::list<fp64>

# zero_handling: Zero and negative zero handling
intersect([-5, -3, -1, 0, 1]::list<i32>, [-3, 0, 2]::list<i32>) = [-3, 0]::list<i32>
intersect([-10, -5, 0]::list<i32>, [-10, -5, 0]::list<i32>) = [-10, -5, 0]::list<i32>
intersect([0, 0, 0]::list<i32>, [0]::list<i32>) = [0]::list<i32>
intersect([0.0, -0.0]::list<fp64>, [0.0]::list<fp64>) = [0.0]::list<fp64>

# empty_values: Empty strings and collections
intersect(['', 'a', 'b']::list<str>, ['', 'b']::list<str>) = ['', 'b']::list<str>
intersect(['', '']::list<str>, ['']::list<str>) = ['']::list<str>

# additional_coverage: Additional test coverage
intersect([1]::list<i32>, [1]::list<i32>) = [1]::list<i32>
intersect([1]::list<i32>, [2]::list<i32>) = []::list<i32>
intersect([5]::list<i32>, []::list<i32>) = []::list<i32>
intersect([1, 2, 2, 3]::list<i32>, [2, 3, 3, 4]::list<i32>) = [2, 3]::list<i32>
intersect([1, 1, 1]::list<i32>, [1, 1]::list<i32>) = [1]::list<i32>
intersect(['x', 'x', 'y', 'y']::list<str>, ['x', 'y', 'y', 'z']::list<str>) = ['x', 'y']::list<str>
intersect([3, 1, 2]::list<i32>, [2, 3, 4]::list<i32>) = [3, 2]::list<i32>
intersect([5, 4, 3, 2, 1]::list<i32>, [1, 2, 3]::list<i32>) = [3, 2, 1]::list<i32>
intersect([100, 200, 300]::list<i16>, [200, 300, 400]::list<i16>) = [200, 300]::list<i16>
intersect([1.1, 2.2, 3.3]::list<fp32>, [2.2, 3.3, 4.4]::list<fp32>) = [2.2, 3.3]::list<fp32>

