### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_set.yaml'

# basic: Basic set union
union([1, 2, 3]::list<i32>, [3, 4, 5]::list<i32>) = [1, 2, 3, 4, 5]::list<i32>
union(['a', 'b']::list<str>, ['b', 'c', 'd']::list<str>) = ['a', 'b', 'c', 'd']::list<str>
union([1, 2]::list<i32>, [3, 4]::list<i32>) = [1, 2, 3, 4]::list<i32>

# empty: Union with empty sets
union([1, 2, 3]::list<i32>, []::list<i32>) = [1, 2, 3]::list<i32>
union([]::list<i32>, [1, 2, 3]::list<i32>) = [1, 2, 3]::list<i32>
union([]::list<i32>, []::list<i32>) = []::list<i32>

# duplicates: Union removes duplicates
union([1, 1, 2, 2]::list<i32>, [2, 2, 3, 3]::list<i32>) = [1, 2, 3]::list<i32>
union(['a', 'a', 'b']::list<str>, ['b', 'c', 'c']::list<str>) = ['a', 'b', 'c']::list<str>

# null_handling: Union with null elements
union([1, null, 3]::list<i32>, [3, 4, null]::list<i32>) = [1, null, 3, 4]::list<i32>
union(null::list<i32>, [1, 2, 3]::list<i32>) = null::list<i32>
union([1, 2, 3]::list<i32>, null::list<i32>) = null::list<i32>

# types: Different data types
union([1.5, 2.5]::list<fp64>, [2.5, 3.5]::list<fp64>) = [1.5, 2.5, 3.5]::list<fp64>
union([true, false]::list<bool>, [false, true]::list<bool>) = [true, false]::list<bool>

# multiple: Union of multiple sets
union([1, 2]::list<i32>, [3, 4]::list<i32>, [5, 6]::list<i32>) = [1, 2, 3, 4, 5, 6]::list<i32>