### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_json.yaml'

# basic: Basic JSON path extraction
json_extract('{"name": "John", "age": 30}'::str, '$.name'::str) = 'John'::str
json_extract('{"name": "John", "age": 30}'::str, '$.age'::str) = '30'::str
json_extract('{"x": 10, "y": 20}'::str, '$.x'::str) = '10'::str

# nested: Nested JSON extraction
json_extract('{"person": {"name": "Jane", "age": 25}}'::str, '$.person.name'::str) = 'Jane'::str
json_extract('{"person": {"name": "Jane", "age": 25}}'::str, '$.person.age'::str) = '25'::str
json_extract('{"data": {"values": [1, 2, 3]}}'::str, '$.data.values'::str) = '[1, 2, 3]'::str

# array: JSON array extraction
json_extract('[1, 2, 3, 4, 5]'::str, '$[0]'::str) = '1'::str
json_extract('[1, 2, 3, 4, 5]'::str, '$[2]'::str) = '3'::str
json_extract('{"items": [{"id": 1}, {"id": 2}]}'::str, '$.items[0].id'::str) = '1'::str

# null_handling: Null and missing paths
json_extract('{"name": "John", "age": null}'::str, '$.age'::str) = null::str
json_extract('{"name": "John"}'::str, '$.missing'::str) = null::str
json_extract(null::str, '$.name'::str) = null::str

# types: Different JSON value types
json_extract('{"flag": true}'::str, '$.flag'::str) = 'true'::str
json_extract('{"value": 3.14}'::str, '$.value'::str) = '3.14'::str
json_extract('{"text": "hello world"}'::str, '$.text'::str) = 'hello world'::str