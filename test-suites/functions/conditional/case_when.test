### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_conditional.yaml'

# basic: Basic CASE WHEN expressions
case_when(true::bool, 1::i32, 2::i32) = 1::i32
case_when(false::bool, 1::i32, 2::i32) = 2::i32
case_when(5::i32 > 3::i32, 'greater'::str, 'not greater'::str) = 'greater'::str
case_when(5::i32 < 3::i32, 'less'::str, 'not less'::str) = 'not less'::str

# multiple_conditions: Multiple WHEN clauses
case_when(1::i32 = 1::i32, 'one'::str, 1::i32 = 2::i32, 'two'::str, 'other'::str) = 'one'::str
case_when(1::i32 = 2::i32, 'two'::str, 1::i32 = 3::i32, 'three'::str, 'other'::str) = 'other'::str
case_when(false::bool, 1::i32, false::bool, 2::i32, true::bool, 3::i32, 4::i32) = 3::i32

# null_handling: CASE with null values
case_when(null::bool, 1::i32, 2::i32) = 2::i32
case_when(true::bool, null::i32, 2::i32) = null::i32
case_when(false::bool, 1::i32, null::i32) = null::i32

# types: Different data types
case_when(true::bool, 1.5::fp64, 2.5::fp64) = 1.5::fp64
case_when(false::bool, 100::i64, 200::i64) = 200::i64
case_when(true::bool, true::bool, false::bool) = true::bool

# nested: Nested CASE expressions
case_when(true::bool, case_when(true::bool, 1::i32, 2::i32), 3::i32) = 1::i32
case_when(false::bool, 1::i32, case_when(true::bool, 2::i32, 3::i32)) = 2::i32

# range_checks: Range checking patterns
case_when(10::i32 < 5::i32, 'low'::str, 10::i32 < 15::i32, 'medium'::str, 'high'::str) = 'medium'::str
case_when(20::i32 < 5::i32, 'low'::str, 20::i32 < 15::i32, 'medium'::str, 'high'::str) = 'high'::str


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# edge_cases: Boundary values and extreme inputs
case_when(2147483647::i32 > 0::i32, 'max'::str, 'other'::str) = 'max'::str
case_when(-2147483648::i32 < 0::i32, 'min'::str, 'other'::str) = 'min'::str
case_when(true::bool, 9223372036854775807::i64, 0::i64) = 9223372036854775807::i64
case_when(true::bool, -9223372036854775808::i64, 0::i64) = -9223372036854775808::i64
case_when(-1::i32 < 0::i32, -2147483648::i32, 2147483647::i32) = -2147483648::i32

# special_values: Special floating point values (NaN, Infinity)
case_when(true::bool, inf::fp64, 0.0::fp64) = inf::fp64
case_when(false::bool, 0.0::fp64, -inf::fp64) = -inf::fp64
case_when(true::bool, nan::fp64, 0.0::fp64) = nan::fp64
case_when(1.0::fp64 > 0.0::fp64, inf::fp32, -inf::fp32) = inf::fp32

# null_handling_extended: Extended null handling scenarios
case_when(false::bool, 1::i32, null::bool, 2::i32, true::bool, 3::i32, 4::i32) = 3::i32
case_when(null::bool, 1::i32, null::bool, 2::i32, true::bool, 3::i32, 4::i32) = 3::i32
case_when(false::bool, 1::i32, null::bool, 2::i32, false::bool, 3::i32, 4::i32) = 4::i32

# zero_handling: Zero and negative zero handling
case_when(5::i32 > 0::i32, 'first'::str, 5::i32 > 0::i32, 'second'::str, 'default'::str) = 'first'::str
case_when(0::i32 = 0::i32, 0::i32, 1::i32) = 0::i32
case_when(0::i64 = 0::i64, 0::i64, 1::i64) = 0::i64
case_when(-5::i32 < 0::i32, 'negative'::str, 'positive'::str) = 'negative'::str
case_when(true::bool, 0.0::fp64, 1.0::fp64) = 0.0::fp64
case_when(false::bool, -0.0::fp64, 0.0::fp64) = 0.0::fp64

# empty_values: Empty strings and collections
case_when(true::bool, ''::str, 'default'::str) = ''::str
case_when(false::bool, 'value'::str, ''::str) = ''::str
case_when(''::str = ''::str, 'match'::str, 'no match'::str) = 'match'::str

# negative_values: Negative number handling
case_when(true::bool, -100::i32, 100::i32) = -100::i32
case_when(-10::i32 > -20::i32, 'greater'::str, 'not greater'::str) = 'greater'::str
case_when(false::bool, 50::i64, -999::i64) = -999::i64

# type_coverage: Various data type coverage
case_when(false::bool, 1::i32, false::bool, 2::i32, false::bool, 3::i32, 4::i32) = 4::i32
case_when(1::i32 = 2::i32, 'a'::str, 3::i32 = 4::i32, 'b'::str, 5::i32 = 6::i32, 'c'::str, 'default'::str) = 'default'::str
case_when(true::bool, 1::i32, true::bool, 2::i32, 3::i32) = 1::i32

# additional_coverage: Additional test coverage
case_when(true::bool, true::bool, true::bool, false::bool, false::bool) = true::bool

