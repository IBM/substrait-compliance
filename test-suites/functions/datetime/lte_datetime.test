### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_datetime.yaml'

# timestamps: examples using the timestamp type
lte('2016-12-31T13:30:15'::ts, '2017-12-31T13:30:15'::ts) = true::bool
lte('2017-12-31T13:30:15'::ts, '2017-12-31T13:30:15'::ts) = true::bool
lte('2018-12-31T13:30:15'::ts, '2017-12-31T13:30:15'::ts) = false::bool

# timestamp_tz: examples using the timestamp_tz type
lte('1999-01-08T01:05:05-08:00'::tstz, '1999-01-08T04:05:06-05:00'::tstz) = true::bool
lte('1999-01-08T01:05:06-08:00'::tstz, '1999-01-08T01:05:06-08:00'::tstz) = true::bool
lte('1999-01-08T01:05:06-08:00'::tstz, '1999-01-08T04:05:05-05:00'::tstz) = false::bool

# date: examples using the date type
lte('2020-12-30'::date, '2020-12-31'::date) = true::bool
lte('2020-12-31'::date, '2020-12-31'::date) = true::bool
lte('2020-12-31'::date, '2020-12-30'::date) = false::bool

# interval: examples using the interval type
lte('P7D'::iday, 'P7D'::iday) = true::bool
lte('P7D'::iday, 'P6D'::iday) = false::bool
lte('P5D'::iday, 'P6D'::iday) = true::bool
lte('P5Y'::iyear, 'P6Y'::iyear) = true::bool
lte('P7Y'::iyear, 'P7Y'::iyear) = true::bool
lte('P7Y'::iyear, 'P6Y'::iyear) = false::bool

# null_input: examples with null args or return
lte(null::iday, 'P5D'::iday) = null::bool
lte(null::date, '2020-12-30'::date) = null::bool
lte(null::ts, '2018-12-31T13:30:15'::ts) = null::bool


# ============================================================================
# ENHANCED TEST CASES
# Additional test cases for comprehensive coverage
# ============================================================================

# null_handling_extended: Extended null handling scenarios
lte('P5D'::iday, null::iday) = null::bool
lte(null::iday, null::iday) = null::bool
lte('2020-12-30'::date, null::date) = null::bool
lte(null::date, null::date) = null::bool
lte('2018-12-31T13:30:15'::ts, null::ts) = null::bool
lte(null::ts, null::ts) = null::bool
lte('1999-01-08T01:05:06-08:00'::tstz, null::tstz) = null::bool
lte(null::tstz, null::tstz) = null::bool
lte('P5Y'::iyear, null::iyear) = null::bool
lte(null::iyear, null::iyear) = null::bool

# zero_handling: Zero and negative zero handling
lte('2020-12-31T23:59:59'::ts, '2021-01-01T00:00:00'::ts) = true::bool
lte('2021-01-01T00:00:00'::ts, '2020-12-31T23:59:59'::ts) = false::bool
lte('1999-01-08T09:05:06Z'::tstz, '1999-01-08T01:05:06-08:00'::tstz) = true::bool
lte('1999-01-08T00:00:00+12:00'::tstz, '1999-01-07T12:00:00Z'::tstz) = true::bool
lte('1999-01-08T00:00:00-12:00'::tstz, '1999-01-08T12:00:00Z'::tstz) = true::bool

# negative_values: Negative number handling
lte('0001-01-01'::date, '0001-01-01'::date) = true::bool
lte('0001-01-01'::date, '9999-12-31'::date) = true::bool
lte('9999-12-31'::date, '9999-12-31'::date) = true::bool
lte('9999-12-31'::date, '0001-01-01'::date) = false::bool
lte('2020-02-29'::date, '2020-03-01'::date) = true::bool
lte('2020-02-29'::date, '2020-02-29'::date) = true::bool
lte('2020-02-29'::date, '2020-02-28'::date) = false::bool
lte('2000-02-29'::date, '1900-03-01'::date) = false::bool
lte('2020-12-31T23:59:59'::ts, '2020-12-31T23:59:59'::ts) = true::bool

# additional_coverage: Additional test coverage
lte('P0D'::iday, 'P1D'::iday) = true::bool
lte('P0D'::iday, 'P0D'::iday) = true::bool
lte('P1D'::iday, 'P0D'::iday) = false::bool
lte('P0Y'::iyear, 'P1Y'::iyear) = true::bool
lte('P0Y'::iyear, 'P0Y'::iyear) = true::bool
lte('P999999Y'::iyear, 'P999999Y'::iyear) = true::bool
lte('P999998Y'::iyear, 'P999999Y'::iyear) = true::bool
lte('P999999Y'::iyear, 'P999998Y'::iyear) = false::bool
lte('P999999D'::iday, 'P999999D'::iday) = true::bool

