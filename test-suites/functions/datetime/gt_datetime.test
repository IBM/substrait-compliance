### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: '/extensions/functions_datetime.yaml'

# timestamps: examples using the timestamp type
gt('2016-12-31T13:30:15'::ts, '2017-12-31T13:30:15'::ts) = false::bool
gt('2018-12-31T13:30:15'::ts, '2017-12-31T13:30:15'::ts) = true::bool

# timestamp_tz: examples using the timestamp_tz type
gt('1999-01-08T01:05:05-08:00'::tstz, '1999-01-08T04:05:06-05:00'::tstz) = false::bool
gt('1999-01-08T01:05:07-08:00'::tstz, '1999-01-08T04:05:06-05:00'::tstz) = true::bool

# date: examples using the date type
gt('2020-12-30'::date, '2020-12-31'::date) = false::bool
gt('2020-12-31'::date, '2020-12-30'::date) = true::bool

# interval: examples using the interval type
gt('P7D'::iday, 'P6D'::iday) = true::bool
gt('P5D'::iday, 'P6D'::iday) = false::bool
gt('P5Y'::iyear, 'P6Y'::iyear) = false::bool
gt('P7Y'::iyear, 'P6Y'::iyear) = true::bool

# null_input: examples with null args
gt(null::iday, 'P5D'::iday) = null::bool
gt(null::date, '2020-12-30'::date) = null::bool
gt(null::ts, '2018-12-31T13:30:15'::ts) = null::bool

# null_handling_extended: Extended null handling scenarios
gt(null::date, null::date) = null::bool
gt(null::ts, null::ts) = null::bool
gt(null::tstz, null::tstz) = null::bool
gt(null::iyear, null::iyear) = null::bool

# zero_handling: Zero and negative zero handling
gt('1999-01-08T01:05:05+00:00'::tstz, '1999-01-08T01:05:05+00:00'::tstz) = false::bool
gt('1999-01-08T01:05:05.999999-08:00'::tstz, '1999-01-08T01:05:05.999998-08:00'::tstz) = true::bool

# negative_values: Negative number handling
gt('2020-12-31'::date, '2020-12-31'::date) = false::bool
gt('2018-12-31T13:30:15'::ts, '2018-12-31T13:30:15'::ts) = false::bool
gt('2018-12-31T13:30:15.123456'::ts, '2018-12-31T13:30:15.123455'::ts) = true::bool
gt('2018-12-31T13:30:15.123455'::ts, '2018-12-31T13:30:15.123456'::ts) = false::bool
gt('9999-12-31'::date, '0001-01-01'::date) = true::bool
gt('0001-01-01'::date, '9999-12-31'::date) = false::bool
gt('P-5D'::iday, 'P0D'::iday) = false::bool
gt('P0D'::iday, 'P-5D'::iday) = true::bool
gt('P-1Y'::iyear, 'P-2Y'::iyear) = true::bool
gt('2020-02-29'::date, '2020-02-28'::date) = true::bool
gt('2020-02-28'::date, '2020-02-29'::date) = false::bool

# additional_coverage: Additional test coverage
gt('P0D'::iday, 'P0D'::iday) = false::bool
gt('P0Y'::iyear, 'P0Y'::iyear) = false::bool
gt('P1Y2M'::iyear, 'P1Y1M'::iyear) = true::bool
gt('P2Y'::iyear, 'P1Y11M'::iyear) = true::bool
gt('P1Y'::iyear, 'P1Y'::iyear) = false::bool
gt('PT23H59M59S'::iday, 'PT0S'::iday) = true::bool
gt('P1DT0H'::iday, 'PT23H59M59S'::iday) = true::bool
gt('PT1S'::iday, 'PT1S'::iday) = false::bool

