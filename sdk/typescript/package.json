{
  "name": "@substrait/compliance",
  "version": "1.0.0",
  "description": "TypeScript/JavaScript SDK for Substrait compliance testing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "substrait",
    "compliance",
    "testing",
    "query-engine",
    "sql"
  ],
  "author": "Substrait Community",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/substrait-io/substrait-compliance.git",
    "directory": "sdk/typescript"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}